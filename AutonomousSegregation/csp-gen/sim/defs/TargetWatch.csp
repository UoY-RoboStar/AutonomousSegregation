						  [[ share__ <- x__ | x__ <- {| share__,setR_counter,setR_done,setR_validObject,setR_targetObjectxy,setR_targetType,setR_closestTargetObject,setR_closestTargetObjectPosition,setR_m,setR_data |} ]] 
						  [[set_closestTargetObject <- setL_closestTargetObject,set_closestTargetObjectPosition <- setL_closestTargetObjectPosition,set_counter <- setL_counter,set_m <- setL_m,set_data <- setL_data,set_done <- setL_done,set_validObject <- setL_validObject,set_targetObjectxy <- setL_targetObjectxy,set_targetType <- setL_targetType]]
						 )
						 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
						 			,setL_closestTargetObject
						 			,setL_closestTargetObjectPosition
						 			,setL_counter
						 			,setL_m
						 			,setL_data
						 			,setL_done
						 			,setL_validObject
						 			,setL_targetObjectxy
						 			,setL_targetType
						 			,setR_counter
						 			 			,setR_done
						 			 			,setR_validObject
						 			 			,setR_targetObjectxy
						 			 			,setR_targetType
						 			 			,setR_closestTargetObject
						 			 			,setR_closestTargetObjectPosition
						 			 			,setR_m
						 			 			,setR_data
						 			|}) |]
						 ((During)
						  [[ share__ <- x__ | x__ <- {| share__,setL_closestTargetObject,setL_closestTargetObjectPosition,setL_counter,setL_m,setL_data,setL_done,setL_validObject,setL_targetObjectxy,setL_targetType |} ]]
						  [[set_counter <- setR_counter,set_done <- setR_done,set_validObject <- setR_validObject,set_targetObjectxy <- setR_targetObjectxy,set_targetType <- setR_targetType,set_closestTargetObject <- setR_closestTargetObject,set_closestTargetObjectPosition <- setR_closestTargetObjectPosition,set_m <- setR_m,set_data <- setR_data]]
						 )
						)[[setL_closestTargetObject <- set_closestTargetObject,setL_closestTargetObjectPosition <- set_closestTargetObjectPosition,setL_counter <- set_counter,setL_m <- set_m,setL_data <- set_data,setL_done <- set_done,setL_validObject <- set_validObject,setL_targetObjectxy <- set_targetObjectxy,setL_targetType <- set_targetType]]
						 [[setR_counter <- set_counter,setR_done <- set_done,setR_validObject <- set_validObject,setR_targetObjectxy <- set_targetObjectxy,setR_targetType <- set_targetType,setR_closestTargetObject <- set_closestTargetObject,setR_closestTargetObjectPosition <- set_closestTargetObjectPosition,setR_m <- set_m,setR_data <- set_data]]
						)\union(enteredSS,{terminate}) 
					)
					During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
							 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
				within
					Inactive [| {terminate} |> SKIP)
					
				VS_O__(id__,cycle_TargetWatch_TargetWatch,
						    const_TargetWatch_ObjectThreshold) = 
				dbisim(let
					Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
					
					Termination = terminate -> SKIP
					
					Active 		= SKIP ; 
							 	  Behaviour ; 
							 	  share__choice(exit -> SKIP) ; SKIP ; 
							 	  share__choice(exited -> SKIP) ; Inactive
				
				
					Behaviour 	= dbisim(
						((
						 (((dbisim(
						 	sbisim(
						 		dbisim(
						 			sbisim(
						 				dbisim(
						 					sbisim(
						 						dbisim(
						 							sbisim(
						 								(let
						 									-- IMPLEMENTATION NOTE:
						 									-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
						 									-- modules for defining the semantics of each node.
						 									enterSS = {|
						 									ValidateTargetObject::enter,
						 									PublishTargetObject::enter,
						 									CalculateTargetObject::enter,
						 									i0::enter,
						 									WaitForDisableTargetWatch::enter
						 									|}
						 									hideSet = union(enterSS,{|exit,exited,internal__|})
						 								within 
						 									((let
						 										-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
						 										-- because CSPM modules are used for the semantics of Node.
						 										flowevts = union(enterSS,{|exit,exited|})
						 										transSync = {|internal__.NID_CalculateTargetObject,endexec__.NID_ValidateTargetObject,internal__.NID_i0,endexec__.NID_PublishTargetObject,endexec__.NID_ValidateTargetObject,internal__.NID_CalculateTargetObject|}
						 									within
						 										((
						 										 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
						 										   ValidateTargetObject::VS_O__(id__,cycle_TargetWatch_TargetWatch,
						 										   		    const_TargetWatch_ObjectThreshold)
						 										   [| { share__, terminate } |] (
						 										   PublishTargetObject::VS_O__(id__,cycle_TargetWatch_TargetWatch,
						 										   		    const_TargetWatch_ObjectThreshold)
						 										   [| { share__, terminate } |] (
						 										   CalculateTargetObject::VS_O__(id__,cycle_TargetWatch_TargetWatch,
						 										   		    const_TargetWatch_ObjectThreshold)
						 										   [| { share__, terminate } |] (
						 										   i0::VS_O__(id__,cycle_TargetWatch_TargetWatch,
						 										   		    const_TargetWatch_ObjectThreshold)
						 										   [| { share__, terminate } |] (
						 										   WaitForDisableTargetWatch::VS_O__(id__,cycle_TargetWatch_TargetWatch,
						 										   		    const_TargetWatch_ObjectThreshold)
						 										   )
						 										   )
						 										   )
						 										   )
						 										 )
						 										 [[ValidateTargetObject::interrupt <- x__ | x__ <- {|interrupt,endexec__.NID_ValidateTargetObject,endexec__.NID_ValidateTargetObject|}]]
						 										 [[PublishTargetObject::interrupt <- x__ | x__ <- {|interrupt,endexec__.NID_PublishTargetObject|}]]
						 										 [[CalculateTargetObject::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_CalculateTargetObject,internal__.NID_CalculateTargetObject|}]]
						 										 [[WaitForDisableTargetWatch::interrupt <- x__ | x__ <- {|interrupt|}]]
						 										 [[i0::interrupt <- x__ | x__ <- {|internal__.NID_i0|}]]
						 										 )
						 										  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
						 										  [[set_counter <- setL_counter,set_validObject <- setL_validObject,set_data <- setL_data]]
						 										 )
						 										 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
						 										 			,setL_counter
						 										 			,setL_validObject
						 										 			,setL_data
						 										|}) |]
						 										 ((i0::enter -> Transitions(id__,cycle_TargetWatch_TargetWatch,
						 										 		    const_TargetWatch_ObjectThreshold))
						 										  [[ share__ <- x__ | x__ <- {| share__,setL_counter,setL_validObject,setL_data |} ]]
						 										 )
						 										)[[setL_counter <- set_counter,setL_validObject <- set_validObject,setL_data <- set_data]]
						 										)
						 									)
						 									 \ hideSet)
						 									[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
						 									[[ endexec_action <- endexec ]]
						 									[[ startexec_action <- startexec ]]
						 								)
						 								[| {|get_CLID_CalculateTargetObject,CalculateTargetObject::entered,terminate|} |]
						 								dbisim(Clock_CLID_CalculateTargetObject(id__,0,
						 										          const_TargetWatch_ObjectThreshold))
						 							)\{|get_CLID_CalculateTargetObject|}
						 						)
						 						[| {|get_CLID_ValidateTargetObject,ValidateTargetObject::entered,terminate|} |]
						 						dbisim(Clock_CLID_ValidateTargetObject(id__,0,
						 								          const_TargetWatch_ObjectThreshold))
						 					)\{|get_CLID_ValidateTargetObject|}
						 				)
						 				[| {|get_CLID_PublishTargetObject,PublishTargetObject::entered,terminate|} |]
						 				dbisim(Clock_CLID_PublishTargetObject(id__,0,
						 						          const_TargetWatch_ObjectThreshold))
						 			)\{|get_CLID_PublishTargetObject|}
						 		)
						 		[| {|get_CLID_WaitForDisableTargetWatch,WaitForDisableTargetWatch::entered,terminate|} |]
						 		dbisim(Clock_CLID_WaitForDisableTargetWatch(id__,0,
						 				          const_TargetWatch_ObjectThreshold))
						 	)\{|get_CLID_WaitForDisableTargetWatch|}
						 )
						 ))
						  [[ share__ <- x__ | x__ <- {| share__,setR_counter,setR_done,setR_validObject,setR_targetObjectxy,setR_targetType,setR_closestTargetObject,setR_closestTargetObjectPosition,setR_m,setR_data |} ]] 
						  [[set_closestTargetObject <- setL_closestTargetObject,set_closestTargetObjectPosition <- setL_closestTargetObjectPosition,set_counter <- setL_counter,set_m <- setL_m,set_data <- setL_data,set_done <- setL_done,set_validObject <- setL_validObject,set_targetObjectxy <- setL_targetObjectxy,set_targetType <- setL_targetType]]
						 )
						 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
						 			,setL_closestTargetObject
						 			,setL_closestTargetObjectPosition
						 			,setL_counter
						 			,setL_m
						 			,setL_data
