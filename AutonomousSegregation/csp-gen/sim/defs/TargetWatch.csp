						 ((During)
						  [[ share__ <- x__ | x__ <- {| share__,setL_closestTargetObject,setL_closestTargetObjectPosition,setL_counter,setL_m,setL_data,setL_done,setL_validObject,setL_targetObjectxy,setL_targetType |} ]]
						  [[set_counter <- setR_counter,set_done <- setR_done,set_validObject <- setR_validObject,set_targetObjectxy <- setR_targetObjectxy,set_targetType <- setR_targetType,set_closestTargetObject <- setR_closestTargetObject,set_closestTargetObjectPosition <- setR_closestTargetObjectPosition,set_m <- setR_m,set_data <- setR_data]]
						 )
						)[[setL_closestTargetObject <- set_closestTargetObject,setL_closestTargetObjectPosition <- set_closestTargetObjectPosition,setL_counter <- set_counter,setL_m <- set_m,setL_data <- set_data,setL_done <- set_done,setL_validObject <- set_validObject,setL_targetObjectxy <- set_targetObjectxy,setL_targetType <- set_targetType]]
						 [[setR_counter <- set_counter,setR_done <- set_done,setR_validObject <- set_validObject,setR_targetObjectxy <- set_targetObjectxy,setR_targetType <- set_targetType,setR_closestTargetObject <- set_closestTargetObject,setR_closestTargetObjectPosition <- set_closestTargetObjectPosition,setR_m <- set_m,setR_data <- set_data]]
						)\{terminate} 
					)
					During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
							 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
				within
					Inactive [| {terminate} |> SKIP)
				
				Transitions(id__,cycle_TargetWatch_TargetWatch,
						    const_TargetWatch_ObjectThreshold) = ((let
					Trans = share__choice(get_counter?counter -> get_CachePointsTW?CachePointsTW -> get_validObject?validObject -> get_data?data -> TimeOut_1(
						 (share__ -> SKIP
						 [] dbisim(((((counter==1)) and member(CachePointsTW,{true.m | m <- LSeq(ClusterData,2)})))&(internal__!NID_CalculateTargetObject -> SKIP ; get_CachePointsTW?b__?x__ -> set_m!x__ -> SKIP
						 ; share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; ValidateTargetObject::enter -> SKIP)))
						 [] dbisim(((validObject==true))&(endexec__.NID_ValidateTargetObject -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; PublishTargetObject::enter -> SKIP)))
						 [] dbisim((true)&(internal__!NID_i0 -> SKIP ;  ((((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; CalculateTargetObject::enter -> SKIP))))
						 [] dbisim((true)&(endexec__.NID_PublishTargetObject -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((share__choice(true & (share__choice(set_counter!0 -> SKIP)));share__choice(get_closestTargetObjectPosition?closestTargetObjectPosition -> registerWrite.o_TargetObject.closestTargetObjectPosition -> SKIP))[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; CalculateTargetObject::enter -> SKIP)))
						 [] dbisim(((validObject==false))&(endexec__.NID_ValidateTargetObject -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((registerWrite.o_InvalidTarget -> SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; WaitForDisableTargetWatch::enter -> SKIP)))
						 [] dbisim(((counter<tuple3_1(data)))&(internal__!NID_CalculateTargetObject -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((share__choice(share__choice(get_counter?counter -> true & (share__choice(set_counter!Plus(counter, 1, core_nat) -> SKIP)))))[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; CalculateTargetObject::enter -> SKIP)))
						 []
						 (exit -> SKIP ; share__choice(exited -> terminate -> SKIP))
						 []
						 terminate -> SKIP
						 []
						 (endexec -> SKIP ; share__choice(startexec -> SKIP))
						 )
					,SKIP);Trans
					)
				within
					Trans [|{terminate}|> SKIP
				)
				)
				
				
				-- Clocks
				Clock_CLID_WaitForDisableTargetWatch(id__,x__,
						          const_TargetWatch_ObjectThreshold) = 
					TimeOut_1(
						WaitForDisableTargetWatch::entered -> Clock_CLID_WaitForDisableTargetWatch(id__,0,
								          const_TargetWatch_ObjectThreshold)
						[]
						get_CLID_WaitForDisableTargetWatch!x__ -> Clock_CLID_WaitForDisableTargetWatch(id__,x__,
								          const_TargetWatch_ObjectThreshold)
						[]
						terminate -> SKIP,Clock_CLID_WaitForDisableTargetWatch(id__,clock_type_plus(x__,1,CLID_WaitForDisableTargetWatch_clock_type(id__,
								          const_TargetWatch_ObjectThreshold)),
								          const_TargetWatch_ObjectThreshold))
				Clock_CLID_PublishTargetObject(id__,x__,
						          const_TargetWatch_ObjectThreshold) = 
					TimeOut_1(
						PublishTargetObject::entered -> Clock_CLID_PublishTargetObject(id__,0,
								          const_TargetWatch_ObjectThreshold)
						[]
						get_CLID_PublishTargetObject!x__ -> Clock_CLID_PublishTargetObject(id__,x__,
								          const_TargetWatch_ObjectThreshold)
						[]
						terminate -> SKIP,Clock_CLID_PublishTargetObject(id__,clock_type_plus(x__,1,CLID_PublishTargetObject_clock_type(id__,
								          const_TargetWatch_ObjectThreshold)),
								          const_TargetWatch_ObjectThreshold))
				Clock_CLID_ValidateTargetObject(id__,x__,
						          const_TargetWatch_ObjectThreshold) = 
					TimeOut_1(
						ValidateTargetObject::entered -> Clock_CLID_ValidateTargetObject(id__,0,
								          const_TargetWatch_ObjectThreshold)
						[]
						get_CLID_ValidateTargetObject!x__ -> Clock_CLID_ValidateTargetObject(id__,x__,
								          const_TargetWatch_ObjectThreshold)
						[]
						terminate -> SKIP,Clock_CLID_ValidateTargetObject(id__,clock_type_plus(x__,1,CLID_ValidateTargetObject_clock_type(id__,
								          const_TargetWatch_ObjectThreshold)),
								          const_TargetWatch_ObjectThreshold))
				Clock_CLID_CalculateTargetObject(id__,x__,
						          const_TargetWatch_ObjectThreshold) = 
					TimeOut_1(
						CalculateTargetObject::entered -> Clock_CLID_CalculateTargetObject(id__,0,
								          const_TargetWatch_ObjectThreshold)
						[]
						get_CLID_CalculateTargetObject!x__ -> Clock_CLID_CalculateTargetObject(id__,x__,
								          const_TargetWatch_ObjectThreshold)
						[]
						terminate -> SKIP,Clock_CLID_CalculateTargetObject(id__,clock_type_plus(x__,1,CLID_CalculateTargetObject_clock_type(id__,
								          const_TargetWatch_ObjectThreshold)),
								          const_TargetWatch_ObjectThreshold))
				
				StateClocks(id__,
						          const_TargetWatch_ObjectThreshold) = dbisim(Clock_CLID_WaitForDisableTargetWatch(id__,0,
						          const_TargetWatch_ObjectThreshold))
				[| { terminate } |] (
				dbisim(Clock_CLID_PublishTargetObject(id__,0,
						          const_TargetWatch_ObjectThreshold))
				[| { terminate } |] (
				dbisim(Clock_CLID_ValidateTargetObject(id__,0,
						          const_TargetWatch_ObjectThreshold))
				[| { terminate } |] (
				dbisim(Clock_CLID_CalculateTargetObject(id__,0,
						          const_TargetWatch_ObjectThreshold))
				)
				)
				)
				
				stateClockSync = {|get_CLID_WaitForDisableTargetWatch,WaitForDisableTargetWatch::entered,get_CLID_PublishTargetObject,PublishTargetObject::entered,get_CLID_ValidateTargetObject,ValidateTargetObject::entered,get_CLID_CalculateTargetObject,CalculateTargetObject::entered|}
			}
		
		endmodule
		----------------------------------------------------------------------
		
		
		----------------------------------------------------------------------
		-- State: WaitingForTarget
		module WaitingForTarget
		
		enterSS = {}
		
		enteredSS = {}
		
		exports
		
			--  Declarations
			channel endexec__ : NIDS
			
			
			channel enter, entered, interrupt
			channel enteredL, enteredR
			
							
			
			--channel increment__
			
			
			--	Nodes
			-- declaring all nodes
			
			
			Timed(OneStep) {
				--	Rule: behaviours(Node)
				--  Note that FDR has problems with efficiently compiling the process below
				-- 	if using a different recursion pattern.
				D__(id__,cycle_TargetWatch_TargetWatch,
						    const_TargetWatch_ObjectThreshold) = 
				dbisim(let
					-- IMPLEMENTATION NOTE: 
					-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
					-- however FDR struggles with that form in certain cases. So we use the exception operator
					-- instead to 'terminate'.
					
					Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
					
					Termination = terminate -> SKIP
					
					Active 		= SKIP ; 
							 	  Behaviour ; 
							 	  share__choice(exit -> SKIP) ; SKIP ; 
							 	  share__choice(exited -> SKIP) ; Inactive
				
					Behaviour 	= entered -> During
					During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
				within
					Inactive [| {terminate} |> SKIP)
					
				VS_O__(id__,cycle_TargetWatch_TargetWatch,
						    const_TargetWatch_ObjectThreshold) = 
				dbisim(let
					Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
					
					Termination = terminate -> SKIP
					
					Active 		= SKIP ; 
							 	  Behaviour ; 
							 	  share__choice(exit -> SKIP) ; SKIP ; 
							 	  share__choice(exited -> SKIP) ; Inactive
				
					Behaviour 	= entered -> During
					During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
				within
					Inactive [| {terminate} |> SKIP)
				
				
				-- Clocks
				
				StateClocks(id__,
						          const_TargetWatch_ObjectThreshold) = terminate -> SKIP
				
				stateClockSync = {||}
			}
		
		endmodule
		----------------------------------------------------------------------
		
		-- END of Nodes --
		
		Timed(OneStep) {
		-- Operation calls --
		-- Only the undefined operations are declared here.
		-- If the state machine is in isolation, all required operations will be undefined.
		-- If it is in the context of a controller, the required operations not provided by the
		-- controller will be declared here, and the defined operations will be defined in the
		-- context of the Controller module, and therefore within scope of the state machine module.
		
		-- END of Operation calls --
	
		datatype SOutputEvents = SOutput_TargetObject
			| SOutput_InvalidTarget
		
		cycle(cycle_TargetWatch_TargetWatch) =
			let
				project(o_TargetObject.x__) = SOutput_TargetObject
				project(o_InvalidTarget) = SOutput_InvalidTarget
		
				Cycle =
					Deadline(
						(registerRead.i_EnableTargetWatch?x__ -> SKIP
							||| registerRead.i_VisibleClustersTW?x__ -> SKIP
							||| registerRead.i_DisableTargetWatch?x__ -> SKIP
							||| registerRead.i_CurrentTypeTW?x__ -> SKIP
							||| registerRead.i_CachePointsTW?x__ -> SKIP);
						startexec -> CollectOutputs(SOutputEvents),0);
					TimeOut_1(terminate -> SKIP,WAIT(cycle_TargetWatch_TargetWatch-1);Cycle)
				
				CollectOutputs(sout) =
					(registerWrite?outp:{ outp | outc <- inter(sout,SOutputEvents), outp <- RegisterDataOutput,project(outp) == outc} -> CollectOutputs(diff(sout,{project(outp)}))
						[]
					endexec -> SKIP
					)
			within
				Cycle
		
		-- STM processes
		STM(id__,cycle_TargetWatch_TargetWatch,
				    const_TargetWatch_ObjectThreshold) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
		(
			cycle(cycle_TargetWatch_TargetWatch)
			[| {| endexec,registerRead,registerWrite,startexec,terminate |} |]
			( 
				(
					(
						(startexec -> IteratedStateful(id__,cycle_TargetWatch_TargetWatch,
								    const_TargetWatch_ObjectThreshold) \ {terminate}) 
						[| {share__} |]
						SKIP
					) ; 
					(let
						Ending = endexec -> (startexec -> Ending [] terminate -> SKIP)
					 within
					 	Ending
					)
				)
				[| union(sharedVarSync,{terminate}) |]
				dbisim(sharedVarMemory(id__,cycle_TargetWatch_TargetWatch,
						    const_TargetWatch_ObjectThreshold))
			)\sharedVarHide
		)\{startexec}
		
		STM_VS_O(id__,cycle_TargetWatch_TargetWatch,
				    const_TargetWatch_ObjectThreshold) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
		(
			cycle(cycle_TargetWatch_TargetWatch)
			[| {| endexec,registerRead,registerWrite,startexec,terminate |} |]
			( 
				(
					(
						(startexec -> IteratedStateful_VS_O(id__,cycle_TargetWatch_TargetWatch,
								    const_TargetWatch_ObjectThreshold) \ {terminate}) 
						[| {share__} |]
						SKIP
					) ; 
					(let
						Ending = endexec -> (startexec -> Ending [] terminate -> SKIP)
					 within
					 	Ending
					)
				)
				[| union(sharedVarSync,{terminate}) |]
				dbisim(sharedVarMemory(id__,cycle_TargetWatch_TargetWatch,
						    const_TargetWatch_ObjectThreshold))
			)\sharedVarHide
		)\{startexec}
		
		-- Transitions
		Transitions(id__,cycle_TargetWatch_TargetWatch,
				    const_TargetWatch_ObjectThreshold) = ((let
			Trans = share__choice(get_CurrentTypeTW?CurrentTypeTW -> get_VisibleClustersTW?VisibleClustersTW -> get_EnableTargetWatch?EnableTargetWatch -> get_DisableTargetWatch?DisableTargetWatch -> TimeOut_1(
				 (share__ -> SKIP
				 [] dbisim((true)&(internal__!NID_i0 -> SKIP ;  ((((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; WaitingForTarget::enter -> SKIP))))
				 [] dbisim((((member(EnableTargetWatch,{true.targetObjectxy | targetObjectxy <- Vec2}) and member(VisibleClustersTW,{true.data | data <- {(x0__,x1__,x2__) | x0__ <- core_nat,x1__ <- LSeq(ClusterData,2),x2__ <- LSeq(ObjectData,2)}})) and member(CurrentTypeTW,{true.targetType | targetType <- core_nat})))&(endexec__.NID_WaitingForTarget -> startexec_action -> SKIP ; get_EnableTargetWatch?b__?x__ -> set_targetObjectxy!x__ -> SKIP;
				 
				 get_VisibleClustersTW?b__?x__ -> set_data!x__ -> SKIP;
				 
				 get_CurrentTypeTW?b__?x__ -> set_targetType!x__ -> SKIP
				 ; share__choice(exit -> SKIP) ; ((let 
				 	X = share__choice(exited -> SKIP [] endexec -> Y)
