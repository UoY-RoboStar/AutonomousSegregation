						 						 		    const_RandomWalk_v_randcoef))
						 						  [[ share__ <- x__ | x__ <- {| share__,setL_randcoef,clockResetL.CLID_T |} ]]
						 						 )
						 						)[[setL_randcoef <- set_randcoef,clockResetL.CLID_T <- clockReset.CLID_T]]
						 						)
						 					)
						 					 \ hideSet)
						 					[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
						 					[[ endexec_action <- endexec ]]
						 					[[ startexec_action <- startexec ]]
						 				)
						 				[| {|get_CLID_Move_Forward,Move_Forward::entered,terminate|} |]
						 				dbisim(Clock_CLID_Move_Forward(id__,0,
						 						          const_RandomWalk_lv,
						 						          const_RandomWalk_av,
						 						          const_RandomWalk_pi,
						 						          const_RandomWalk_v_randcoef))
						 			)\{|get_CLID_Move_Forward|}
						 		)
						 		[| {|get_CLID_Turn,Turn::entered,terminate|} |]
						 		dbisim(Clock_CLID_Turn(id__,0,
						 				          const_RandomWalk_lv,
						 				          const_RandomWalk_av,
						 				          const_RandomWalk_pi,
						 				          const_RandomWalk_v_randcoef))
						 	)\{|get_CLID_Turn|}
						 )
						 ))
						  [[ share__ <- x__ | x__ <- {| share__,setR_rwCmd,setR_randcoef,setR_sign,clockResetR.CLID_T |} ]] 
						  [[set_rwCmd <- setL_rwCmd,set_randcoef <- setL_randcoef,set_sign <- setL_sign,clockReset.CLID_T <- clockResetL.CLID_T]]
						 )
						 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
						 			,setL_rwCmd
						 			,setL_randcoef
						 			,setL_sign
						 			,clockResetL.CLID_T
						 			,setR_rwCmd
						 			 			,setR_randcoef
						 			 			,setR_sign
						 			 			,clockResetR.CLID_T
						 			|}) |]
						 ((During)
						  [[ share__ <- x__ | x__ <- {| share__,setL_rwCmd,setL_randcoef,setL_sign,clockResetL.CLID_T |} ]]
						  [[set_rwCmd <- setR_rwCmd,set_randcoef <- setR_randcoef,set_sign <- setR_sign,clockReset.CLID_T <- clockResetR.CLID_T]]
						 )
						)[[setL_rwCmd <- set_rwCmd,setL_randcoef <- set_randcoef,setL_sign <- set_sign,clockResetL.CLID_T <- clockReset.CLID_T]]
						 [[setR_rwCmd <- set_rwCmd,setR_randcoef <- set_randcoef,setR_sign <- set_sign,clockResetR.CLID_T <- clockReset.CLID_T]]
						)\{terminate} 
					)
					During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
							 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
				within
					Inactive [| {terminate} |> SKIP)
				
				Transitions(id__,cycle_RandomWalk_RandomWalk,
						    const_RandomWalk_lv,
						    const_RandomWalk_av,
						    const_RandomWalk_pi,
						    const_RandomWalk_v_randcoef) = ((let
					Trans = share__choice(get_randcoef?randcoef -> get_CLID_T?T -> TimeOut_1(
						 (share__ -> SKIP
						 [] dbisim((true)&(internal__!NID_i0 -> SKIP ;  ((((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Turn::enter -> SKIP))))
						 [] dbisim(((T>=randcoef))&(endexec__.NID_Turn -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((share__choice(get_rwCmd?rwCmd -> true & (registerWrite!o_rwCmd!update_Vec2_x(rwCmd,0) -> SKIP));share__choice(share__choice(get_rwCmd?rwCmd -> true & (share__choice(set_rwCmd!update_Vec2_y(rwCmd,0) -> SKIP))));share__choice(get_rwCmd?rwCmd -> registerWrite.o_RWMove.rwCmd -> SKIP);share__choice(clockReset.CLID_T -> SKIP);share__choice(true & (share__choice(set_randcoef!randomcoef() -> SKIP)));share__choice(true & (share__choice(set_sign!random_sign() -> SKIP))))[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Move_Forward::enter -> SKIP)))
						 [] dbisim(((T>=randcoef))&(endexec__.NID_Move_Forward -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((share__choice(share__choice(get_rwCmd?rwCmd -> true & (share__choice(set_rwCmd!update_Vec2_x(rwCmd,0) -> SKIP))));share__choice(share__choice(get_rwCmd?rwCmd -> true & (share__choice(set_rwCmd!update_Vec2_y(rwCmd,0) -> SKIP))));share__choice(get_rwCmd?rwCmd -> registerWrite.o_RWMove.rwCmd -> SKIP);share__choice(clockReset.CLID_T -> SKIP);share__choice(true & (share__choice(set_randcoef!randomcoef() -> SKIP))))[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Turn::enter -> SKIP)))
						 [] dbisim(((T<randcoef))&(endexec__.NID_Move_Forward -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Move_Forward::enter -> SKIP)))
						 [] dbisim(((T<randcoef))&(endexec__.NID_Turn -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Turn::enter -> SKIP)))
						 []
						 (exit -> SKIP ; share__choice(exited -> terminate -> SKIP))
						 []
						 terminate -> SKIP
						 []
						 (endexec -> SKIP ; share__choice(startexec -> SKIP))
						 )
					,SKIP);Trans
					)
				within
					Trans [|{terminate}|> SKIP
				)
				)
				
				
				-- Clocks
				Clock_CLID_Turn(id__,x__,
						          const_RandomWalk_lv,
						          const_RandomWalk_av,
						          const_RandomWalk_pi,
						          const_RandomWalk_v_randcoef) = 
					TimeOut_1(
						Turn::entered -> Clock_CLID_Turn(id__,0,
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef)
						[]
						get_CLID_Turn!x__ -> Clock_CLID_Turn(id__,x__,
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef)
						[]
						terminate -> SKIP,Clock_CLID_Turn(id__,clock_type_plus(x__,1,CLID_Turn_clock_type(id__,
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef)),
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef))
				Clock_CLID_Move_Forward(id__,x__,
						          const_RandomWalk_lv,
						          const_RandomWalk_av,
						          const_RandomWalk_pi,
						          const_RandomWalk_v_randcoef) = 
					TimeOut_1(
						Move_Forward::entered -> Clock_CLID_Move_Forward(id__,0,
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef)
						[]
						get_CLID_Move_Forward!x__ -> Clock_CLID_Move_Forward(id__,x__,
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef)
						[]
						terminate -> SKIP,Clock_CLID_Move_Forward(id__,clock_type_plus(x__,1,CLID_Move_Forward_clock_type(id__,
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef)),
								          const_RandomWalk_lv,
								          const_RandomWalk_av,
