				let
					max = (clock_type_max(Union({
			{}
			}))+1)
				ctype = {0..max}
			within
				if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
			
			
			
			-- RoboSim-specific declarations
			channel endexec, endexec_action
			channel endexec__ : NIDS
			channel startexec, startexec_action
			
			-- declaring registerRead/Write datatypes
			datatype RegisterDataInput = i_closestDistance.Bool.core_real
				| i_closestAngle.Bool.core_real
				| i_EnableOA.Bool
				| i_NOAMove.Bool.Vec2
				| i_DisableOA.Bool
			
			
			datatype RegisterDataOutput = o_OAMove.Vec2
			
			
			nametype RegisterOutputs = {|
			o_OAMove|}
				
			nametype RegisterInputs = {|
			i_closestDistance,
			i_closestAngle,
			i_EnableOA,
			i_NOAMove,
			i_DisableOA|}
			
			channel registerRead 	: RegisterDataInput
			channel registerWrite 	: RegisterDataOutput
			
			-- variable channels
			channel get_closestDistance : Bool.core_real
			channel get_closestAngle : Bool.core_real
			channel get_EnableOA : Bool
			channel get_DisableOA : Bool
			channel get_NOAMove : Bool.Vec2
			
			-- channel set with all visible events
			sem__events = {|endexec,terminate
						,registerRead
						,registerWrite
				|}
		
				-- Nodes --
				-- declaring all nodes
				
				----------------------------------------------------------------------
				-- State: OAEnabled
				module OAEnabled
				
				enterSS = {}
				
				enteredSS = {}
				
				exports
				
					--  Declarations
					channel endexec__ : NIDS
					
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					
					--channel increment__
					
					
					--	Nodes
					-- declaring all nodes
					
					
					Timed(OneStep) {
						--	Rule: behaviours(Node)
						--  Note that FDR has problems with efficiently compiling the process below
						-- 	if using a different recursion pattern.
						D__(id__,cycle_ObstacleAvoidance_ObstacleAvoidance,
								    const_ObstacleAvoidance_pi,
								    const_ObstacleAvoidance_DISTANCE,
								    const_ObstacleAvoidance_min_range,
								    const_ObstacleAvoidance_max_range,
								    const_ObstacleAvoidance_v_closest_angle,
								    const_ObstacleAvoidance_v_closest_distance,
								    const_ObstacleAvoidance_v_av,
								    const_ObstacleAvoidance_v_lv) = 
						dbisim(let
