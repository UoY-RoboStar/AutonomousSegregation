				ctrl_ref0::registerRead.ctrl_ref0::i_VisibleClustersTW!x__ -> SKIP)
				|||
			(registerRead.i_closestDistance?x__ ->
				ctrl_ref0::registerRead.ctrl_ref0::i_closestDistance!x__ -> SKIP)
				|||
			(registerRead.i_VisibleClustersCA?x__ ->
				ctrl_ref0::registerRead.ctrl_ref0::i_VisibleClustersCA!x__ -> SKIP)
				|||
			(registerRead.i_ObjectCarried?x__ ->
				ctrl_ref0::registerRead.ctrl_ref0::i_ObjectCarried!x__ -> SKIP)
				|||
			(registerRead.i_closestAngle?x__ ->
				ctrl_ref0::registerRead.ctrl_ref0::i_closestAngle!x__ -> SKIP)
				|||
			(registerRead.i_Coord_O?x__ ->
				ctrl_ref0::registerRead.ctrl_ref0::i_Coord_O!x__ -> SKIP))
					);
			-- synchronize on events related to evars
			-- collect outputs, and monitor termination of the cycle, by all controllers
			(CollectOutputs(COutputEvents) [| {endexec} |] Monitor),0);
			-- wait for the cycleDef period
			TimeOut_1(terminate -> SKIP,WAIT(cycle_CacheCons_CacheCons-1));
			-- recurse
			CycleModule
								
		CollectOutputs(sout) =
			(
			ctrl_ref0::registerWrite?outp:{ outp | outc <- diff(sout,EVarsEvents), outp <- ctrl_ref0::RegisterDataOutput, connected_ctrl_ref0(outp), project_ctrl_ref0(outp) == outc}
			 	-> registerWrite!lift_ctrl_ref0(outp)
			 		-> CollectOutputs(diff(sout,{project_ctrl_ref0(outp)}))
			[]
			endexec -> SKIP
			)
			
		Monitor = 
			(	 (ctrl_ref0::endexec -> SKIP)); endexec -> SKIP
		
	within
		CycleModule 
	
	-- (Rule 5) memoryComp(...) : CSPProcess
	memoryComp(id__) = (
		STOP)
	
	
	-- (Rule 1) [[ M : SimModule ]]_M : CSPProcess
	D__(id__,cycle_CacheCons_CacheCons,
			    const_CacheConsC_stm_ref0_lv,
			    const_CacheConsC_stm_ref0_av,
			    const_CacheConsC_stm_ref0_pi,
			    const_CacheConsC_stm_ref0_k1,
			    const_CacheConsC_stm_ref0_timeout,
			    const_CacheConsC_stm_ref0_timeout_PUSH,
			    const_CacheConsC_stm_ref0_timeout_BACKUP,
			    const_CacheConsC_stm_ref0_timeout_EXILE,
