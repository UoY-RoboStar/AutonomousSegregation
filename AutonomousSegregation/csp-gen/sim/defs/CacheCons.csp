								          const_RandomWalk_pi,
								          const_RandomWalk_v_randcoef) = 
							TimeOut_1(
								Move_Forward::entered -> Clock_CLID_Move_Forward(id__,0,
										          const_RandomWalk_lv,
										          const_RandomWalk_av,
										          const_RandomWalk_pi,
										          const_RandomWalk_v_randcoef)
								[]
								get_CLID_Move_Forward!x__ -> Clock_CLID_Move_Forward(id__,x__,
										          const_RandomWalk_lv,
										          const_RandomWalk_av,
										          const_RandomWalk_pi,
