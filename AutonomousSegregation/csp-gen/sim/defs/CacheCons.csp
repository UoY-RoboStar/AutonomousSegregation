						    const_RandomWalk_pi,
						    const_RandomWalk_v_randcoef) = ((let
					Trans = share__choice(get_EnableClusterWatch?EnableClusterWatch -> get_DisableClusterWatch?DisableClusterWatch -> TimeOut_1(
						 (share__ -> SKIP
						 [] dbisim((true)&(internal__!NID_i0 -> SKIP ;  ((((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Wait::enter -> SKIP))))
						 [] dbisim(((not (member(EnableClusterWatch,{true}))))&(endexec__.NID_Wait -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Wait::enter -> SKIP)))
						 [] dbisim((member(EnableClusterWatch,{true}))&(internal__!NID_Wait -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((endexec -> startexec -> SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Wander::enter -> SKIP)))
						 [] dbisim((member(DisableClusterWatch,{true}))&(endexec__.NID_Wander -> startexec_action -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((share__choice(share__choice(get_rwCmd?rwCmd -> true & (share__choice(set_rwCmd!update_Vec2_x(rwCmd,0) -> SKIP))));share__choice(share__choice(get_rwCmd?rwCmd -> true & (share__choice(set_rwCmd!update_Vec2_y(rwCmd,0) -> SKIP))));share__choice(get_rwCmd?rwCmd -> registerWrite.o_RWMove.rwCmd -> SKIP))[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; Wait::enter -> SKIP)))
						 []
						 (exit -> SKIP ; share__choice(exited -> terminate -> SKIP))
						 []
						 terminate -> SKIP
						 []
						 (endexec -> SKIP ; share__choice(startexec -> SKIP))
						 )
					,SKIP);Trans
					)
				within
					Trans [|{terminate}|> SKIP
