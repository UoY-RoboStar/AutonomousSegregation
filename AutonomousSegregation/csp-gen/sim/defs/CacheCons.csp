			    const_CacheConsC_stm_ref0_LINEAR_HOME,
			    const_CacheConsC_stm_ref5_lv,
			    const_CacheConsC_stm_ref5_av,
			    const_CacheConsC_stm_ref5_pi,
			    const_CacheConsC_stm_ref5_v_randcoef,
			    const_CacheConsC_stm_ref4_ObjectThreshold,
			    const_CacheConsC_stm_ref2_pi,
			    const_CacheConsC_stm_ref2_DISTANCE,
			    const_CacheConsC_stm_ref2_min_range,
			    const_CacheConsC_stm_ref2_max_range,
			    const_CacheConsC_stm_ref2_v_closest_angle,
			    const_CacheConsC_stm_ref2_v_closest_distance,
			    const_CacheConsC_stm_ref2_v_av,
			    const_CacheConsC_stm_ref2_v_lv) =
	timed_priority(
		(
			(
				(
					(
						dbisim(cycleModule(id__,cycle_CacheCons_CacheCons))
								[| Union({{||},
										  {||},
										  {||},
										  {||}}) |]
									memoryComp(id__)
						)\{||}
					[| {| 	terminate,tock,
							ctrl_ref0::endexec,ctrl_ref0::registerRead,ctrl_ref0::registerWrite	|} |]
					-- (Rule 6) composeControllers(...) : CSPProcess
						((let
								cycle_CacheConsC_CacheConsC = cycle_CacheCons_CacheCons
							within
								(ctrl_ref0::D__(id__,cycle_CacheConsC_CacheConsC,
										    const_CacheConsC_stm_ref0_lv,
										    const_CacheConsC_stm_ref0_av,
										    const_CacheConsC_stm_ref0_pi,
										    const_CacheConsC_stm_ref0_k1,
										    const_CacheConsC_stm_ref0_timeout,
										    const_CacheConsC_stm_ref0_timeout_PUSH,
										    const_CacheConsC_stm_ref0_timeout_BACKUP,
										    const_CacheConsC_stm_ref0_timeout_EXILE,
										    const_CacheConsC_stm_ref0_PUSH_LV,
										    const_CacheConsC_stm_ref0_TARGET_AV,
										    const_CacheConsC_stm_ref0_ANGLE_DIFF,
										    const_CacheConsC_stm_ref0_ANGLE_DIFF_TOLERANCE,
										    const_CacheConsC_stm_ref0_LINEAR_HOME,
										    const_CacheConsC_stm_ref5_lv,
										    const_CacheConsC_stm_ref5_av,
										    const_CacheConsC_stm_ref5_pi,
										    const_CacheConsC_stm_ref5_v_randcoef,
										    const_CacheConsC_stm_ref4_ObjectThreshold,
										    const_CacheConsC_stm_ref2_pi,
										    const_CacheConsC_stm_ref2_DISTANCE,
										    const_CacheConsC_stm_ref2_min_range,
										    const_CacheConsC_stm_ref2_max_range,
										    const_CacheConsC_stm_ref2_v_closest_angle,
										    const_CacheConsC_stm_ref2_v_closest_distance,
										    const_CacheConsC_stm_ref2_v_av,
										    const_CacheConsC_stm_ref2_v_lv)
								\{| |})
									[[ctrl_ref0::terminate <- terminate]]
							)
						)
				) \ {|	endexec,
						ctrl_ref0::endexec,ctrl_ref0::registerRead,ctrl_ref0::registerWrite |}
			) [| {terminate} |> SKIP
		) \ {terminate}
	)
	
	
	
	O__(id__,cycle_CacheCons_CacheCons,
			    const_CacheConsC_stm_ref0_lv,
			    const_CacheConsC_stm_ref0_av,
			    const_CacheConsC_stm_ref0_pi,
			    const_CacheConsC_stm_ref0_k1,
			    const_CacheConsC_stm_ref0_timeout,
			    const_CacheConsC_stm_ref0_timeout_PUSH,
			    const_CacheConsC_stm_ref0_timeout_BACKUP,
			    const_CacheConsC_stm_ref0_timeout_EXILE,
