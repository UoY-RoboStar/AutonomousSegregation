				-- Nodes --
				-- declaring all nodes
				
				----------------------------------------------------------------------
				-- Initial: i0
				module i0
				exports
				
					channel enter, interrupt
					
					Timed(OneStep) {
						D__(id__,cycle_MoveManager_MoveManager) = 
							dbisim(let
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= share__choice(interrupt -> SKIP) ; Inactive
							within
								Inactive [| {terminate} |> SKIP)
						
						VS_O__(id__,cycle_MoveManager_MoveManager) = D__(id__,cycle_MoveManager_MoveManager)
					}
				
				endmodule
				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: MoveHandler
				module MoveHandler
				
				enterSS = {}
				
				enteredSS = {}
				
				exports
				
					--  Declarations
					channel endexec__ : NIDS
					
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					
					--channel increment__
					
					
					--	Nodes
					-- declaring all nodes
					
					
					Timed(OneStep) {
						--	Rule: behaviours(Node)
						--  Note that FDR has problems with efficiently compiling the process below
						-- 	if using a different recursion pattern.
						D__(id__,cycle_MoveManager_MoveManager) = 
						dbisim(let
							-- IMPLEMENTATION NOTE: 
							-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
							-- however FDR struggles with that form in certain cases. So we use the exception operator
							-- instead to 'terminate'.
							
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= share__choice(get_cmd?cmd -> true&CALL__move(
										id__,
										cmd
									));share__choice(get_NOAcmd?NOAcmd -> registerWrite.o_NOAMove.NOAcmd -> SKIP) ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
							Behaviour 	= entered -> During
							During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
						within
							Inactive [| {terminate} |> SKIP)
							
						VS_O__(id__,cycle_MoveManager_MoveManager) = 
						dbisim(let
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= share__choice(get_cmd?cmd -> true&CALL__move(
										id__,
										cmd
									));share__choice(get_NOAcmd?NOAcmd -> registerWrite.o_NOAMove.NOAcmd -> SKIP) ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
							Behaviour 	= entered -> During
							During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
						within
							Inactive [| {terminate} |> SKIP)
						
						
						-- Clocks
						
						StateClocks(id__) = terminate -> SKIP
						
						stateClockSync = {||}
					}
				
				endmodule
				----------------------------------------------------------------------
				
				-- END of Nodes --
				
				Timed(OneStep) {
				-- Operation calls --
				-- Only the undefined operations are declared here.
				-- If the state machine is in isolation, all required operations will be undefined.
				-- If it is in the context of a controller, the required operations not provided by the
				-- controller will be declared here, and the defined operations will be defined in the
				-- context of the Controller module, and therefore within scope of the state machine module.
				CALL__move(id__,
							param_cmd) = EDeadline(registerWrite.o_move.param_cmd,0)
				
				-- END of Operation calls --
			
				datatype SOutputEvents = SOutput_NOAMove
					| SOutput_move
				
				cycle(cycle_MoveManager_MoveManager) =
					let
						project(o_NOAMove.x__) = SOutput_NOAMove
						project(o_move.x__) = SOutput_move
				
						Cycle =
							Deadline(
								(registerRead.i_RWMove?x__ -> SKIP
									||| registerRead.i_CCMove?x__ -> SKIP
									||| registerRead.i_OAMove?x__ -> SKIP);
								startexec -> CollectOutputs(SOutputEvents),0);
							TimeOut_1(terminate -> SKIP,WAIT(cycle_MoveManager_MoveManager-1);Cycle)
						
						CollectOutputs(sout) =
							(registerWrite?outp:{ outp | outc <- inter(sout,SOutputEvents), outp <- RegisterDataOutput,project(outp) == outc} -> CollectOutputs(diff(sout,{project(outp)}))
								[]
							endexec -> SKIP
							)
					within
						Cycle
				
				-- STM processes
				STM(id__,cycle_MoveManager_MoveManager) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
				(
					cycle(cycle_MoveManager_MoveManager)
					[| {| endexec,registerRead,registerWrite,startexec,terminate |} |]
					( 
						(
							(
								(startexec -> IteratedStateful(id__,cycle_MoveManager_MoveManager) \ {terminate}) 
								[| {share__} |]
								SKIP
							) ; 
							(let
								Ending = endexec -> (startexec -> Ending [] terminate -> SKIP)
							 within
							 	Ending
							)
						)
						[| union(sharedVarSync,{terminate}) |]
						dbisim(sharedVarMemory(id__,cycle_MoveManager_MoveManager))
					)\sharedVarHide
				)\{startexec}
				
				STM_VS_O(id__,cycle_MoveManager_MoveManager) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
				(
					cycle(cycle_MoveManager_MoveManager)
					[| {| endexec,registerRead,registerWrite,startexec,terminate |} |]
					( 
						(
							(
								(startexec -> IteratedStateful_VS_O(id__,cycle_MoveManager_MoveManager) \ {terminate}) 
								[| {share__} |]
								SKIP
							) ; 
							(let
								Ending = endexec -> (startexec -> Ending [] terminate -> SKIP)
							 within
							 	Ending
							)
						)
						[| union(sharedVarSync,{terminate}) |]
						dbisim(sharedVarMemory(id__,cycle_MoveManager_MoveManager))
					)\sharedVarHide
				)\{startexec}
				
				-- Transitions
				Transitions(id__,cycle_MoveManager_MoveManager) = ((let
					Trans = share__choice(get_OAMove?OAMove -> get_RWMove?RWMove -> get_CCMove?CCMove -> TimeOut_1(
						 (share__ -> SKIP
						 [] dbisim(((((member(RWMove,{true.cmd | cmd <- Vec2}) and member(RWMove,{true.NOAcmd | NOAcmd <- Vec2})) and (not (member(OAMove,{true.x__ | x__ <- Vec2})))) and (not (member(CCMove,{true.x__ | x__ <- Vec2})))))&(endexec__.NID_MoveHandler -> startexec_action -> SKIP ; get_RWMove?b__?x__ -> set_cmd!x__ -> SKIP;
						 
						 get_RWMove?b__?x__ -> set_NOAcmd!x__ -> SKIP
						 ; share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; MoveHandler::enter -> SKIP)))
						 [] dbisim((true)&(internal__!NID_i0 -> SKIP ;  ((((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; MoveHandler::enter -> SKIP))))
						 [] dbisim((((member(CCMove,{true.cmd | cmd <- Vec2}) and member(CCMove,{true.NOAcmd | NOAcmd <- Vec2})) and (not (member(OAMove,{true.x__ | x__ <- Vec2})))))&(endexec__.NID_MoveHandler -> startexec_action -> SKIP ; get_CCMove?b__?x__ -> set_cmd!x__ -> SKIP;
						 
						 get_CCMove?b__?x__ -> set_NOAcmd!x__ -> SKIP
						 ; share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; MoveHandler::enter -> SKIP)))
						 [] dbisim((((member(OAMove,{true.cmd | cmd <- Vec2}) and member(RWMove,{true.NOAcmd | NOAcmd <- Vec2})) and (not (member(CCMove,{true.x__ | x__ <- Vec2})))))&(endexec__.NID_MoveHandler -> startexec_action -> SKIP ; get_OAMove?b__?x__ -> set_cmd!x__ -> SKIP;
						 
						 get_RWMove?b__?x__ -> set_NOAcmd!x__ -> SKIP
						 ; share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; MoveHandler::enter -> SKIP)))
						 [] dbisim((((member(OAMove,{true.cmd | cmd <- Vec2}) and member(CCMove,{true.NOAcmd | NOAcmd <- Vec2})) and (not (member(RWMove,{true.x__ | x__ <- Vec2})))))&(endexec__.NID_MoveHandler -> startexec_action -> SKIP ; get_OAMove?b__?x__ -> set_cmd!x__ -> SKIP;
						 
						 get_CCMove?b__?x__ -> set_NOAcmd!x__ -> SKIP
						 ; share__choice(exit -> SKIP) ; ((let 
						 	X = share__choice(exited -> SKIP [] endexec -> Y)
						 	Y = share__choice(exited -> SKIP [] startexec -> X)
						  within
						  	X) ; ((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; MoveHandler::enter -> SKIP)))
						 []
						 (exit -> SKIP ; share__choice(exited -> terminate -> SKIP))
						 []
						 terminate -> SKIP
						 []
						 (endexec -> SKIP ; share__choice(startexec -> SKIP))
						 )
					,SKIP);Trans
					)
				within
					Trans [|{terminate}|> SKIP
				)
				)
				
				-- Stateful
				-- RULE: Stateful(stm:StateMachineBody) : CSPProcess
				
				-- Named process definitions
				MachineBody(id__,cycle_MoveManager_MoveManager) = 
					dbisim((
					let
						finalNodesEntered = {||}
					within
						(dbisim((dbisim((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i0::enter,
							MoveHandler::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited|})
								transSync = {|endexec__.NID_MoveHandler,internal__.NID_i0,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i0::D__(id__,cycle_MoveManager_MoveManager)
								   [| { share__, terminate } |] (
								   MoveHandler::D__(id__,cycle_MoveManager_MoveManager)
								   )
								 )
								 [[MoveHandler::interrupt <- x__ | x__ <- {|interrupt,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler|}]]
								 [[i0::interrupt <- x__ | x__ <- {|internal__.NID_i0|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								 )
								 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
								|}) |]
								 ((i0::enter -> Transitions(id__,cycle_MoveManager_MoveManager))
								  [[ share__ <- x__ | x__ <- {| share__ |} ]]
								 )
								)
								)
							)
							 \ hideSet)
							[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
							[[ endexec_action <- endexec ]]
							[[ startexec_action <- startexec ]]
						)
						)
						 [| union(stateClockSync,{terminate}) |]
						 StateClocks(id__)
						)\diff(stateClockSync,enteredSS))
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour(id__,cycle_MoveManager_MoveManager) = 
					dbisim((let
						stateClockSync = {|get_CLID_MoveHandler,MoveHandler::entered|}
					 within
						(MachineBody(id__,cycle_MoveManager_MoveManager) [| union(stateClockSync,{terminate}) |] StateClocks(id__)) \ union(stateClockSync,enteredSS)
					)
					)
				
				IteratedBehaviour(id__,cycle_MoveManager_MoveManager) = 
					dbisim((let
						stateClockSync = {|get_CLID_MoveHandler,MoveHandler::entered|}
					 within
						(dbisim(
							sbisim(
								MachineBody(id__,cycle_MoveManager_MoveManager)
								[| {|get_CLID_MoveHandler,MoveHandler::entered,terminate|} |]
								dbisim(Clock_CLID_MoveHandler(id__,0))
							)\{|get_CLID_MoveHandler|}
						)
						) \ union(stateClockSync,enteredSS)
					)
					)
				
				Stateful(id__,cycle_MoveManager_MoveManager) = 
					((let
						getsetLocalChannels = {|get_NOAcmd,set_NOAcmd,
						get_cmd,set_cmd|}
						clockSync = {||}
					within
						(Behaviour(id__,cycle_MoveManager_MoveManager) 
						 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
						 (varMemory(id__,cycle_MoveManager_MoveManager) [| {terminate} |] Clocks(id__))
					 	)\union(getsetLocalChannels,clockSync)
					)
					)
				
				IteratedStateful(id__,cycle_MoveManager_MoveManager) =
					(dbisim(
						sbisim(
							dbisim(
								sbisim(
									IteratedBehaviour(id__,cycle_MoveManager_MoveManager)
									[| {|get_cmd,set_cmd,terminate|} |]
									Memory_cmd((0,0))
								)\{|get_cmd,set_cmd|}
							)
							[| {|get_NOAcmd,set_NOAcmd,terminate|} |]
							Memory_NOAcmd((0,0))
						)\{|get_NOAcmd,set_NOAcmd|}
					)
					)
				
				-- Visible counterparts
				MachineBody_VS_O(id__,cycle_MoveManager_MoveManager) = 
					dbisim((
					let
						finalNodesEntered = {||}
					within
						(dbisim((dbisim((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i0::enter,
							MoveHandler::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited|})
								transSync = {|endexec__.NID_MoveHandler,internal__.NID_i0,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i0::VS_O__(id__,cycle_MoveManager_MoveManager)
								   [| { share__, terminate } |] (
								   MoveHandler::VS_O__(id__,cycle_MoveManager_MoveManager)
								   )
								 )
								 [[MoveHandler::interrupt <- x__ | x__ <- {|interrupt,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler,endexec__.NID_MoveHandler|}]]
								 [[i0::interrupt <- x__ | x__ <- {|internal__.NID_i0|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								 )
								 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
								|}) |]
								 ((i0::enter -> Transitions(id__,cycle_MoveManager_MoveManager))
								  [[ share__ <- x__ | x__ <- {| share__ |} ]]
								 )
								)
								)
							)
							 \ hideSet)
							[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
							[[ endexec_action <- endexec ]]
							[[ startexec_action <- startexec ]]
						)
						)
						 [| union(stateClockSync,{terminate}) |]
						 StateClocks(id__)
						)\diff(stateClockSync,enteredSS))
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour_VS_O(id__,cycle_MoveManager_MoveManager) = 
					dbisim((let
						stateClockSync = {|get_CLID_MoveHandler,MoveHandler::entered|}
					 within
						(MachineBody_VS_O(id__,cycle_MoveManager_MoveManager) [| union(stateClockSync,{terminate}) |] StateClocks(id__)) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				IteratedBehaviour_VS_O(id__,cycle_MoveManager_MoveManager) = 
					dbisim((let
						stateClockSync = {|get_CLID_MoveHandler,MoveHandler::entered|}
					 within
						(dbisim(
							sbisim(
								MachineBody_VS_O(id__,cycle_MoveManager_MoveManager)
								[| {|get_CLID_MoveHandler,MoveHandler::entered,terminate|} |]
								dbisim(Clock_CLID_MoveHandler(id__,0))
							)\{|get_CLID_MoveHandler|}
						)
						) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				Stateful_VS_O(id__,cycle_MoveManager_MoveManager) = 
					dbisim((let
						getsetLocalChannels = {|get_NOAcmd,set_NOAcmd,
						get_cmd,set_cmd|}
						clockSync = {||}
					within
						(Behaviour_VS_O(id__,cycle_MoveManager_MoveManager) 
						 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
						 (varMemory(id__,cycle_MoveManager_MoveManager) [| {terminate} |] Clocks(id__))
					 	)\union(getsetLocalChannels,clockSync)
					)
					)
				
				IteratedStateful_VS_O(id__,cycle_MoveManager_MoveManager) =
					(dbisim(
						sbisim(
							dbisim(
								sbisim(
									IteratedBehaviour_VS_O(id__,cycle_MoveManager_MoveManager)
									[| {|get_cmd,set_cmd,terminate|} |]
									Memory_cmd((0,0))
								)\{|get_cmd,set_cmd|}
							)
							[| {|get_NOAcmd,set_NOAcmd,terminate|} |]
							Memory_NOAcmd((0,0))
						)\{|get_NOAcmd,set_NOAcmd|}
					)
					)
				
				-- END
				
				-- Memory
				-- Memory variables
				Memory_NOAcmd(NOAcmd) =
					get_NOAcmd!NOAcmd -> Memory_NOAcmd(NOAcmd)
					[]
					set_NOAcmd?x__ -> Memory_NOAcmd(x__)
					[]
					terminate -> SKIP
				Memory_cmd(cmd) =
					get_cmd!cmd -> Memory_cmd(cmd)
					[]
					set_cmd?x__ -> Memory_cmd(x__)
					[]
					terminate -> SKIP
				
				-- varMemory process
				varMemory(id__,cycle_MoveManager_MoveManager) = Memory_NOAcmd((0,0))
				[| { terminate } |] (
				Memory_cmd((0,0))
				)
				
				getsetLocalChannels = {|get_NOAcmd,set_NOAcmd,get_cmd,set_cmd|}
				
				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__,cycle_MoveManager_MoveManager) = STM_VS_O(id__,cycle_MoveManager_MoveManager) \ localClockResets
				D__(id__,cycle_MoveManager_MoveManager) = timed_priority(STM(id__,cycle_MoveManager_MoveManager) \ union(internal_events,localClockResets))
				O__(id__,cycle_MoveManager_MoveManager) = dbisim(D__(id__,cycle_MoveManager_MoveManager))
				VS__(id__,cycle_MoveManager_MoveManager) = FVS__(id__,cycle_MoveManager_MoveManager)
				VS_O__(id__,cycle_MoveManager_MoveManager) = dbisim(FVS__(id__,cycle_MoveManager_MoveManager))
				HEXT__(id__,cycle_MoveManager_MoveManager) = O__(id__,cycle_MoveManager_MoveManager) [|shared_variable_events|] SKIP
				FVS_C__(id__,cycle_MoveManager_MoveManager) = dbisim(timed_priority(STM(id__,cycle_MoveManager_MoveManager) \ internal_events))
				HUP__(id__,cycle_MoveManager_MoveManager) = timed_priority(O__(id__,cycle_MoveManager_MoveManager) [|{share__}|] SKIP)
				
				-- Clocks
				
				Clocks(id__) = terminate -> SKIP
				
				clockSync = {||}
				
				Clock_CLID_MoveHandler(id__,x__) = 
					TimeOut_1(
						MoveHandler::entered -> Clock_CLID_MoveHandler(id__,0)
						[]
						get_CLID_MoveHandler!x__ -> Clock_CLID_MoveHandler(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_MoveHandler(id__,clock_type_plus(x__,1,CLID_MoveHandler_clock_type(id__))))
				
				StateClocks(id__) = dbisim(Clock_CLID_MoveHandler(id__,0))
				
				stateClockSync = {|get_CLID_MoveHandler,MoveHandler::entered|}
				
				
				-- Shared memory
				-- Shared memory variables
				
				Memory_CCMove(x__) = (
					get_CCMove!x__ -> Memory_CCMove(x__)
					[]
					registerRead.i_CCMove?x__ -> Memory_CCMove(x__)
					[]
					terminate -> SKIP
				)
				Memory_OAMove(x__) = (
					get_OAMove!x__ -> Memory_OAMove(x__)
					[]
					registerRead.i_OAMove?x__ -> Memory_OAMove(x__)
					[]
					terminate -> SKIP
				)
				Memory_RWMove(x__) = (
					get_RWMove!x__ -> Memory_RWMove(x__)
					[]
					registerRead.i_RWMove?x__ -> Memory_RWMove(x__)
					[]
					terminate -> SKIP
				)
				
				-- sharedVarMemory process
				sharedVarMemory(id__,cycle_MoveManager_MoveManager) = (
				 (terminate -> SKIP
				 )
				 [| { terminate } |]
				 (Memory_CCMove(false.(0,0))
				 [| { terminate } |] (
				 Memory_OAMove(false.(0,0))
				 [| { terminate } |] (
				 Memory_RWMove(false.(0,0))
				 )
				 )
				 )
				)
				
				sharedVarSync = union({|get_CCMove,
				get_OAMove,
				get_RWMove|},
					  {||}
					 )
				
				sharedVarHide = union({|get_CCMove,
				get_OAMove,
				get_RWMove|},
					  {||}
					 )
				
				}
		endmodule
		
		Timed(OneStep) {
		CALL__move(id__,
				    param_cmd) 	= moveCall.param_cmd -> SKIP
		CALL__DepositObject(id__) 	= DepositObjectCall -> SKIP
		}
		
		Timed(OneStep) {
		-- (Rule 8) cycleController(...) : CSPProcess
		datatype SOutputEvents = SOutput_OAMove
			| SOutput_NOAMove
			| SOutput_DisableTargetWatch
			| SOutput_DepositObject
			| SOutput_EnableOA
			| SOutput_CurrentTypeTW
			| SOutput_DisableClusterWatch
			| SOutput_CurrentTypeCA
			| SOutput_move
			| SOutput_CCMove
			| SOutput_DisableOA
			| SOutput_EnableClusterWatch
			| SOutput_InvalidTarget
			| SOutput_CachePointsTW
			| SOutput_CachePointsCC
			| SOutput_TargetObject
			| SOutput_RWMove
			| SOutput_EnableTargetWatch
		
		DVarsEvents = {}
		
		nametype EVarsEvents = {|SOutput_OAMove
			, SOutput_NOAMove
			, SOutput_DisableTargetWatch
			, SOutput_EnableOA
			, SOutput_CurrentTypeTW
			, SOutput_DisableClusterWatch
			, SOutput_CurrentTypeCA
			, SOutput_CCMove
			, SOutput_DisableOA
			, SOutput_EnableClusterWatch
			, SOutput_InvalidTarget
			, SOutput_CachePointsTW
			, SOutput_CachePointsCC
			, SOutput_TargetObject
			, SOutput_RWMove
			, SOutput_EnableTargetWatch|}	
		
		cycleController(id__,cycle_CacheConsC_CacheConsC,
				    const_CacheConsC_stm_ref0_lv,
				    const_CacheConsC_stm_ref0_av,
				    const_CacheConsC_stm_ref0_pi,
				    const_CacheConsC_stm_ref0_k1,
				    const_CacheConsC_stm_ref0_timeout,
				    const_CacheConsC_stm_ref0_timeout_PUSH,
				    const_CacheConsC_stm_ref0_timeout_BACKUP,
				    const_CacheConsC_stm_ref0_timeout_EXILE,
				    const_CacheConsC_stm_ref0_PUSH_LV,
				    const_CacheConsC_stm_ref0_TARGET_AV,
				    const_CacheConsC_stm_ref0_ANGLE_DIFF,
				    const_CacheConsC_stm_ref0_ANGLE_DIFF_TOLERANCE,
				    const_CacheConsC_stm_ref0_LINEAR_HOME,
				    const_CacheConsC_stm_ref5_lv,
				    const_CacheConsC_stm_ref5_av,
				    const_CacheConsC_stm_ref5_pi,
				    const_CacheConsC_stm_ref5_v_randcoef,
				    const_CacheConsC_stm_ref4_ObjectThreshold,
				    const_CacheConsC_stm_ref2_pi,
				    const_CacheConsC_stm_ref2_DISTANCE,
				    const_CacheConsC_stm_ref2_min_range,
				    const_CacheConsC_stm_ref2_max_range,
				    const_CacheConsC_stm_ref2_v_closest_angle,
				    const_CacheConsC_stm_ref2_v_closest_distance,
				    const_CacheConsC_stm_ref2_v_av,
				    const_CacheConsC_stm_ref2_v_lv) =
		let
					
			project_stm_ref2(stm_ref2::o_OAMove.x__) = SOutput_OAMove
			project_stm_ref1(stm_ref1::o_NOAMove.x__) = SOutput_NOAMove
			project_stm_ref1(stm_ref1::o_move.x__) = SOutput_move
			project_stm_ref0(stm_ref0::o_DisableTargetWatch) = SOutput_DisableTargetWatch
			project_stm_ref0(stm_ref0::o_DepositObject) = SOutput_DepositObject
			project_stm_ref0(stm_ref0::o_EnableOA) = SOutput_EnableOA
			project_stm_ref0(stm_ref0::o_CurrentTypeTW.x__) = SOutput_CurrentTypeTW
			project_stm_ref0(stm_ref0::o_DisableClusterWatch) = SOutput_DisableClusterWatch
			project_stm_ref0(stm_ref0::o_CurrentTypeCA.x__) = SOutput_CurrentTypeCA
			project_stm_ref0(stm_ref0::o_CCMove.x__) = SOutput_CCMove
			project_stm_ref0(stm_ref0::o_DisableOA) = SOutput_DisableOA
			project_stm_ref0(stm_ref0::o_EnableClusterWatch) = SOutput_EnableClusterWatch
			project_stm_ref0(stm_ref0::o_EnableTargetWatch.x__) = SOutput_EnableTargetWatch
			project_stm_ref4(stm_ref4::o_InvalidTarget) = SOutput_InvalidTarget
			project_stm_ref4(stm_ref4::o_TargetObject.x__) = SOutput_TargetObject
			project_stm_ref3(stm_ref3::o_CachePointsTW.x__) = SOutput_CachePointsTW
			project_stm_ref3(stm_ref3::o_CachePointsCC.x__) = SOutput_CachePointsCC
			project_stm_ref5(stm_ref5::o_RWMove.x__) = SOutput_RWMove
		
			connected_stm_ref2(stm_ref2::o_OAMove.x__) = true
			connected_stm_ref2(_) = false
			connected_stm_ref1(stm_ref1::o_NOAMove.x__) = true
			connected_stm_ref1(stm_ref1::o_move.x__) = true
			connected_stm_ref1(_) = false
			connected_stm_ref0(stm_ref0::o_DisableTargetWatch) = true
			connected_stm_ref0(stm_ref0::o_DepositObject) = true
			connected_stm_ref0(stm_ref0::o_EnableOA) = true
			connected_stm_ref0(stm_ref0::o_CurrentTypeTW.x__) = true
			connected_stm_ref0(stm_ref0::o_DisableClusterWatch) = true
			connected_stm_ref0(stm_ref0::o_CurrentTypeCA.x__) = true
			connected_stm_ref0(stm_ref0::o_CCMove.x__) = true
			connected_stm_ref0(stm_ref0::o_DisableOA) = true
			connected_stm_ref0(stm_ref0::o_EnableClusterWatch) = true
			connected_stm_ref0(stm_ref0::o_EnableTargetWatch.x__) = true
			connected_stm_ref0(_) = false
			connected_stm_ref4(stm_ref4::o_InvalidTarget) = true
			connected_stm_ref4(stm_ref4::o_TargetObject.x__) = true
			connected_stm_ref4(_) = false
			connected_stm_ref3(stm_ref3::o_CachePointsTW.x__) = true
			connected_stm_ref3(stm_ref3::o_CachePointsCC.x__) = true
			connected_stm_ref3(_) = false
			connected_stm_ref5(stm_ref5::o_RWMove.x__) = true
			connected_stm_ref5(_) = false
		
			lift_stm_ref0(stm_ref0::o_DepositObject) = o_DepositObject
			lift_stm_ref1(stm_ref1::o_move.x__) = o_move.x__
			
			CycleController =
				Deadline(
				-- read inputs from the controller and pass to state machines
				(
				((registerRead.i_closestAngle?x__ ->
					((stm_ref2::registerRead.stm_ref2::i_closestAngle!x__ -> SKIP)))
					|||
				(registerRead.i_VisibleClustersCC?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_VisibleClustersCC!x__ -> SKIP)))
					|||
				(registerRead.i_ObjectCarried?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_ObjectCarried!x__ -> SKIP)))
					|||
				(registerRead.i_VisibleClustersTW?x__ ->
					((stm_ref4::registerRead.stm_ref4::i_VisibleClustersTW!x__ -> SKIP)))
					|||
				(registerRead.i_closestDistance?x__ ->
					((stm_ref2::registerRead.stm_ref2::i_closestDistance!x__ -> SKIP)))
					|||
				(registerRead.i_VisibleClustersCA?x__ ->
					((stm_ref3::registerRead.stm_ref3::i_VisibleClustersCA!x__ -> SKIP)))
					|||
				(registerRead.i_Coord_O?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_Coord_O!x__ -> SKIP))))
				-- ensure state machines read the values being communicated via evars
				||| ((stm_ref1::registerRead.stm_ref1::i_OAMove?x__ -> SKIP)
					|||
				
		(stm_ref2::registerRead.stm_ref2::i_NOAMove?x__ -> SKIP)
					|||
				
		(stm_ref4::registerRead.stm_ref4::i_DisableTargetWatch?x__ -> SKIP)
					|||
				
		(stm_ref2::registerRead.stm_ref2::i_EnableOA?x__ -> SKIP)
					|||
				
		(stm_ref4::registerRead.stm_ref4::i_CurrentTypeTW?x__ -> SKIP)
					|||
				
		(stm_ref5::registerRead.stm_ref5::i_DisableClusterWatch?x__ -> SKIP)
					|||
				
		(stm_ref3::registerRead.stm_ref3::i_CurrentTypeCA?x__ -> SKIP)
					|||
				
		(stm_ref1::registerRead.stm_ref1::i_CCMove?x__ -> SKIP)
					|||
				
		(stm_ref2::registerRead.stm_ref2::i_DisableOA?x__ -> SKIP)
					|||
				
		(stm_ref5::registerRead.stm_ref5::i_EnableClusterWatch?x__ -> SKIP)
					|||
				
		(stm_ref0::registerRead.stm_ref0::i_InvalidTarget?x__ -> SKIP)
					|||
				
		(stm_ref4::registerRead.stm_ref4::i_CachePointsTW?x__ -> SKIP)
					|||
				
		(stm_ref0::registerRead.stm_ref0::i_CachePointsCC?x__ -> SKIP)
					|||
				
		(stm_ref0::registerRead.stm_ref0::i_TargetObject?x__ -> SKIP)
					|||
				
		(stm_ref1::registerRead.stm_ref1::i_RWMove?x__ -> SKIP)
					|||
				
		(stm_ref4::registerRead.stm_ref4::i_EnableTargetWatch?x__ -> SKIP)
		)		);
				-- synchronize on events related to evars to erase memory
				((registerWriteE.e_OAMove -> SKIP)
					|||
				(registerWriteE.e_NOAMove -> SKIP)
					|||
				(registerWriteE.e_DisableTargetWatch -> SKIP)
					|||
				(registerWriteE.e_EnableOA -> SKIP)
					|||
				(registerWriteE.e_CurrentTypeTW -> SKIP)
					|||
				(registerWriteE.e_DisableClusterWatch -> SKIP)
					|||
				(registerWriteE.e_CurrentTypeCA -> SKIP)
					|||
				(registerWriteE.e_CCMove -> SKIP)
					|||
				(registerWriteE.e_DisableOA -> SKIP)
					|||
				(registerWriteE.e_EnableClusterWatch -> SKIP)
					|||
				(registerWriteE.e_InvalidTarget -> SKIP)
					|||
				(registerWriteE.e_CachePointsTW -> SKIP)
					|||
				(registerWriteE.e_CachePointsCC -> SKIP)
					|||
				(registerWriteE.e_TargetObject -> SKIP)
					|||
				(registerWriteE.e_RWMove -> SKIP)
					|||
				(registerWriteE.e_EnableTargetWatch -> SKIP));
				-- collect outputs, and monitor termination of the cycle, by all controllers
				(CollectOutputs(SOutputEvents) [| {endexec} |] Monitor),0);
				-- wait for the cycleDef period
				TimeOut_1(terminate -> SKIP,WAIT(cycle_CacheConsC_CacheConsC-1));
				-- recurse
				CycleController
				
										
			CollectOutputs(sout) =
				(stm_ref0::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- stm_ref0::RegisterDataOutput, connected_stm_ref0(outp), project_stm_ref0(outp) == outc}
						-> registerWrite!lift_stm_ref0(outp)
							-> CollectOutputs(diff(sout,{project_stm_ref0(outp)}))
				[]
				stm_ref1::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- stm_ref1::RegisterDataOutput, connected_stm_ref1(outp), project_stm_ref1(outp) == outc}
						-> registerWrite!lift_stm_ref1(outp)
							-> CollectOutputs(diff(sout,{project_stm_ref1(outp)}))
				[]
				stm_ref2::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref2::RegisterDataOutput, connected_stm_ref2(outp), project_stm_ref2(outp) == outc}
						-> CollectOutputs(diff(sout,{project_stm_ref2(outp)}))
				[]
				stm_ref1::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref1::RegisterDataOutput, connected_stm_ref1(outp), project_stm_ref1(outp) == outc}
						-> CollectOutputs(diff(sout,{project_stm_ref1(outp)}))
				[]
				stm_ref0::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref0::RegisterDataOutput, connected_stm_ref0(outp), project_stm_ref0(outp) == outc}
						-> CollectOutputs(diff(sout,{project_stm_ref0(outp)}))
				[]
				stm_ref4::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref4::RegisterDataOutput, connected_stm_ref4(outp), project_stm_ref4(outp) == outc}
						-> CollectOutputs(diff(sout,{project_stm_ref4(outp)}))
				[]
				stm_ref3::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref3::RegisterDataOutput, connected_stm_ref3(outp), project_stm_ref3(outp) == outc}
						-> CollectOutputs(diff(sout,{project_stm_ref3(outp)}))
				[]
				stm_ref5::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref5::RegisterDataOutput, connected_stm_ref5(outp), project_stm_ref5(outp) == outc}
						-> CollectOutputs(diff(sout,{project_stm_ref5(outp)}))
				[]
				endexec -> SKIP
				)
		
			Monitor = 
				(	 (stm_ref0::endexec -> SKIP)
				|||	 (stm_ref5::endexec -> SKIP)
				|||	 (stm_ref4::endexec -> SKIP)
				|||	 (stm_ref3::endexec -> SKIP)
				|||	 (stm_ref2::endexec -> SKIP)
				|||	 (stm_ref1::endexec -> SKIP)); endexec -> SKIP
		within
			CycleController
		
		-- (Rule 5) memoryComp(...) : CSPProcess
		memoryComp(id__,
				    const_CacheConsC_stm_ref0_lv,
				    const_CacheConsC_stm_ref0_av,
				    const_CacheConsC_stm_ref0_pi,
				    const_CacheConsC_stm_ref0_k1,
				    const_CacheConsC_stm_ref0_timeout,
				    const_CacheConsC_stm_ref0_timeout_PUSH,
				    const_CacheConsC_stm_ref0_timeout_BACKUP,
				    const_CacheConsC_stm_ref0_timeout_EXILE,
				    const_CacheConsC_stm_ref0_PUSH_LV,
				    const_CacheConsC_stm_ref0_TARGET_AV,
				    const_CacheConsC_stm_ref0_ANGLE_DIFF,
				    const_CacheConsC_stm_ref0_ANGLE_DIFF_TOLERANCE,
				    const_CacheConsC_stm_ref0_LINEAR_HOME,
				    const_CacheConsC_stm_ref5_lv,
				    const_CacheConsC_stm_ref5_av,
				    const_CacheConsC_stm_ref5_pi,
				    const_CacheConsC_stm_ref5_v_randcoef,
				    const_CacheConsC_stm_ref4_ObjectThreshold,
				    const_CacheConsC_stm_ref2_pi,
				    const_CacheConsC_stm_ref2_DISTANCE,
				    const_CacheConsC_stm_ref2_min_range,
				    const_CacheConsC_stm_ref2_max_range,
				    const_CacheConsC_stm_ref2_v_closest_angle,
				    const_CacheConsC_stm_ref2_v_closest_distance,
				    const_CacheConsC_stm_ref2_v_av,
				    const_CacheConsC_stm_ref2_v_lv) = (
			Memory_OAMove(false.(0,0))
			||| Memory_NOAMove(false.(0,0))
			||| Memory_DisableTargetWatch(false)
			||| Memory_EnableOA(false)
			||| Memory_CurrentTypeTW(false.0)
			||| Memory_DisableClusterWatch(false)
			||| Memory_CurrentTypeCA(false.0)
			||| Memory_CCMove(false.(0,0))
			||| Memory_DisableOA(false)
			||| Memory_EnableClusterWatch(false)
			||| Memory_InvalidTarget(false)
			||| Memory_CachePointsTW(false.<>)
			||| Memory_CachePointsCC(false.<>)
			||| Memory_TargetObject(false.(0,0))
			||| Memory_RWMove(false.(0,0))
			||| Memory_EnableTargetWatch(false.(0,0))
			)
		
		Memory_OAMove(x__) = (
			registerWriteE.e_OAMove -> Memory_OAMove(false.(0,0))
			[]
			stm_ref2::registerWrite.stm_ref2::o_OAMove?x__ -> Memory_OAMove(true.x__)
			[]
			stm_ref1::registerRead.stm_ref1::i_OAMove!x__ -> Memory_OAMove(x__)
		)
		Memory_NOAMove(x__) = (
			registerWriteE.e_NOAMove -> Memory_NOAMove(false.(0,0))
			[]
			stm_ref1::registerWrite.stm_ref1::o_NOAMove?x__ -> Memory_NOAMove(true.x__)
			[]
			stm_ref2::registerRead.stm_ref2::i_NOAMove!x__ -> Memory_NOAMove(x__)
		)
		Memory_DisableTargetWatch(x__) = (
			registerWriteE.e_DisableTargetWatch -> Memory_DisableTargetWatch(false)
			[]
			stm_ref0::registerWrite.stm_ref0::o_DisableTargetWatch -> Memory_DisableTargetWatch(true)
			[]
			stm_ref4::registerRead.stm_ref4::i_DisableTargetWatch!x__ -> Memory_DisableTargetWatch(x__)
		)
		Memory_EnableOA(x__) = (
			registerWriteE.e_EnableOA -> Memory_EnableOA(false)
			[]
			stm_ref0::registerWrite.stm_ref0::o_EnableOA -> Memory_EnableOA(true)
			[]
			stm_ref2::registerRead.stm_ref2::i_EnableOA!x__ -> Memory_EnableOA(x__)
		)
		Memory_CurrentTypeTW(x__) = (
			registerWriteE.e_CurrentTypeTW -> Memory_CurrentTypeTW(false.0)
			[]
			stm_ref0::registerWrite.stm_ref0::o_CurrentTypeTW?x__ -> Memory_CurrentTypeTW(true.x__)
			[]
			stm_ref4::registerRead.stm_ref4::i_CurrentTypeTW!x__ -> Memory_CurrentTypeTW(x__)
		)
		Memory_DisableClusterWatch(x__) = (
			registerWriteE.e_DisableClusterWatch -> Memory_DisableClusterWatch(false)
			[]
			stm_ref0::registerWrite.stm_ref0::o_DisableClusterWatch -> Memory_DisableClusterWatch(true)
			[]
			stm_ref5::registerRead.stm_ref5::i_DisableClusterWatch!x__ -> Memory_DisableClusterWatch(x__)
		)
		Memory_CurrentTypeCA(x__) = (
			registerWriteE.e_CurrentTypeCA -> Memory_CurrentTypeCA(false.0)
			[]
			stm_ref0::registerWrite.stm_ref0::o_CurrentTypeCA?x__ -> Memory_CurrentTypeCA(true.x__)
			[]
			stm_ref3::registerRead.stm_ref3::i_CurrentTypeCA!x__ -> Memory_CurrentTypeCA(x__)
		)
		Memory_CCMove(x__) = (
			registerWriteE.e_CCMove -> Memory_CCMove(false.(0,0))
			[]
			stm_ref0::registerWrite.stm_ref0::o_CCMove?x__ -> Memory_CCMove(true.x__)
			[]
			stm_ref1::registerRead.stm_ref1::i_CCMove!x__ -> Memory_CCMove(x__)
		)
		Memory_DisableOA(x__) = (
			registerWriteE.e_DisableOA -> Memory_DisableOA(false)
			[]
			stm_ref0::registerWrite.stm_ref0::o_DisableOA -> Memory_DisableOA(true)
			[]
			stm_ref2::registerRead.stm_ref2::i_DisableOA!x__ -> Memory_DisableOA(x__)
		)
		Memory_EnableClusterWatch(x__) = (
			registerWriteE.e_EnableClusterWatch -> Memory_EnableClusterWatch(false)
			[]
			stm_ref0::registerWrite.stm_ref0::o_EnableClusterWatch -> Memory_EnableClusterWatch(true)
			[]
			stm_ref5::registerRead.stm_ref5::i_EnableClusterWatch!x__ -> Memory_EnableClusterWatch(x__)
		)
		Memory_InvalidTarget(x__) = (
			registerWriteE.e_InvalidTarget -> Memory_InvalidTarget(false)
			[]
			stm_ref4::registerWrite.stm_ref4::o_InvalidTarget -> Memory_InvalidTarget(true)
			[]
			stm_ref0::registerRead.stm_ref0::i_InvalidTarget!x__ -> Memory_InvalidTarget(x__)
		)
		Memory_CachePointsTW(x__) = (
			registerWriteE.e_CachePointsTW -> Memory_CachePointsTW(false.<>)
			[]
			stm_ref3::registerWrite.stm_ref3::o_CachePointsTW?x__ -> Memory_CachePointsTW(true.x__)
			[]
			stm_ref4::registerRead.stm_ref4::i_CachePointsTW!x__ -> Memory_CachePointsTW(x__)
		)
		Memory_CachePointsCC(x__) = (
			registerWriteE.e_CachePointsCC -> Memory_CachePointsCC(false.<>)
			[]
			stm_ref3::registerWrite.stm_ref3::o_CachePointsCC?x__ -> Memory_CachePointsCC(true.x__)
			[]
			stm_ref0::registerRead.stm_ref0::i_CachePointsCC!x__ -> Memory_CachePointsCC(x__)
		)
		Memory_TargetObject(x__) = (
			registerWriteE.e_TargetObject -> Memory_TargetObject(false.(0,0))
			[]
			stm_ref4::registerWrite.stm_ref4::o_TargetObject?x__ -> Memory_TargetObject(true.x__)
			[]
			stm_ref0::registerRead.stm_ref0::i_TargetObject!x__ -> Memory_TargetObject(x__)
		)
		Memory_RWMove(x__) = (
			registerWriteE.e_RWMove -> Memory_RWMove(false.(0,0))
			[]
			stm_ref5::registerWrite.stm_ref5::o_RWMove?x__ -> Memory_RWMove(true.x__)
			[]
			stm_ref1::registerRead.stm_ref1::i_RWMove!x__ -> Memory_RWMove(x__)
		)
		Memory_EnableTargetWatch(x__) = (
			registerWriteE.e_EnableTargetWatch -> Memory_EnableTargetWatch(false.(0,0))
			[]
			stm_ref0::registerWrite.stm_ref0::o_EnableTargetWatch?x__ -> Memory_EnableTargetWatch(true.x__)
			[]
			stm_ref4::registerRead.stm_ref4::i_EnableTargetWatch!x__ -> Memory_EnableTargetWatch(x__)
		)
		
		-- (Rule 7) [[ c : Controller ]]_C : CSPProcess
		D__(id__,cycle_CacheConsC_CacheConsC,
				    const_CacheConsC_stm_ref0_lv,
				    const_CacheConsC_stm_ref0_av,
				    const_CacheConsC_stm_ref0_pi,
				    const_CacheConsC_stm_ref0_k1,
				    const_CacheConsC_stm_ref0_timeout,
				    const_CacheConsC_stm_ref0_timeout_PUSH,
				    const_CacheConsC_stm_ref0_timeout_BACKUP,
				    const_CacheConsC_stm_ref0_timeout_EXILE,
				    const_CacheConsC_stm_ref0_PUSH_LV,
				    const_CacheConsC_stm_ref0_TARGET_AV,
				    const_CacheConsC_stm_ref0_ANGLE_DIFF,
				    const_CacheConsC_stm_ref0_ANGLE_DIFF_TOLERANCE,
				    const_CacheConsC_stm_ref0_LINEAR_HOME,
				    const_CacheConsC_stm_ref5_lv,
				    const_CacheConsC_stm_ref5_av,
				    const_CacheConsC_stm_ref5_pi,
				    const_CacheConsC_stm_ref5_v_randcoef,
				    const_CacheConsC_stm_ref4_ObjectThreshold,
				    const_CacheConsC_stm_ref2_pi,
				    const_CacheConsC_stm_ref2_DISTANCE,
				    const_CacheConsC_stm_ref2_min_range,
				    const_CacheConsC_stm_ref2_max_range,
				    const_CacheConsC_stm_ref2_v_closest_angle,
				    const_CacheConsC_stm_ref2_v_closest_distance,
				    const_CacheConsC_stm_ref2_v_av,
				    const_CacheConsC_stm_ref2_v_lv) =
		timed_priority(
			(
				(
					(
						(
						dbisim(cycleController(id__,cycle_CacheConsC_CacheConsC,
								    const_CacheConsC_stm_ref0_lv,
								    const_CacheConsC_stm_ref0_av,
								    const_CacheConsC_stm_ref0_pi,
								    const_CacheConsC_stm_ref0_k1,
								    const_CacheConsC_stm_ref0_timeout,
								    const_CacheConsC_stm_ref0_timeout_PUSH,
								    const_CacheConsC_stm_ref0_timeout_BACKUP,
								    const_CacheConsC_stm_ref0_timeout_EXILE,
								    const_CacheConsC_stm_ref0_PUSH_LV,
								    const_CacheConsC_stm_ref0_TARGET_AV,
								    const_CacheConsC_stm_ref0_ANGLE_DIFF,
								    const_CacheConsC_stm_ref0_ANGLE_DIFF_TOLERANCE,
								    const_CacheConsC_stm_ref0_LINEAR_HOME,
								    const_CacheConsC_stm_ref5_lv,
								    const_CacheConsC_stm_ref5_av,
								    const_CacheConsC_stm_ref5_pi,
								    const_CacheConsC_stm_ref5_v_randcoef,
								    const_CacheConsC_stm_ref4_ObjectThreshold,
								    const_CacheConsC_stm_ref2_pi,
								    const_CacheConsC_stm_ref2_DISTANCE,
								    const_CacheConsC_stm_ref2_min_range,
								    const_CacheConsC_stm_ref2_max_range,
								    const_CacheConsC_stm_ref2_v_closest_angle,
								    const_CacheConsC_stm_ref2_v_closest_distance,
								    const_CacheConsC_stm_ref2_v_av,
								    const_CacheConsC_stm_ref2_v_lv))
					 	 [| Union({{||},
					 	 		  {|registerWriteE|},
					 	 		  {|stm_ref1::registerRead.stm_ref1::i_OAMove,
					 	 		  	stm_ref2::registerRead.stm_ref2::i_NOAMove,
					 	 		  	stm_ref4::registerRead.stm_ref4::i_DisableTargetWatch,
					 	 		  	stm_ref2::registerRead.stm_ref2::i_EnableOA,
					 	 		  	stm_ref4::registerRead.stm_ref4::i_CurrentTypeTW,
					 	 		  	stm_ref5::registerRead.stm_ref5::i_DisableClusterWatch,
					 	 		  	stm_ref3::registerRead.stm_ref3::i_CurrentTypeCA,
					 	 		  	stm_ref1::registerRead.stm_ref1::i_CCMove,
					 	 		  	stm_ref2::registerRead.stm_ref2::i_DisableOA,
					 	 		  	stm_ref5::registerRead.stm_ref5::i_EnableClusterWatch,
					 	 		  	stm_ref0::registerRead.stm_ref0::i_InvalidTarget,
					 	 		  	stm_ref4::registerRead.stm_ref4::i_CachePointsTW,
					 	 		  	stm_ref0::registerRead.stm_ref0::i_CachePointsCC,
					 	 		  	stm_ref0::registerRead.stm_ref0::i_TargetObject,
					 	 		  	stm_ref1::registerRead.stm_ref1::i_RWMove,
					 	 		  	stm_ref4::registerRead.stm_ref4::i_EnableTargetWatch|},
					 	 		  {|stm_ref2::registerWrite.stm_ref2::o_OAMove,
					 	 		  	stm_ref1::registerWrite.stm_ref1::o_NOAMove,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_DisableTargetWatch,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_EnableOA,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_CurrentTypeTW,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_DisableClusterWatch,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_CurrentTypeCA,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_CCMove,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_DisableOA,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_EnableClusterWatch,
					 	 		  	stm_ref4::registerWrite.stm_ref4::o_InvalidTarget,
					 	 		  	stm_ref3::registerWrite.stm_ref3::o_CachePointsTW,
					 	 		  	stm_ref3::registerWrite.stm_ref3::o_CachePointsCC,
					 	 		  	stm_ref4::registerWrite.stm_ref4::o_TargetObject,
					 	 		  	stm_ref5::registerWrite.stm_ref5::o_RWMove,
					 	 		  	stm_ref0::registerWrite.stm_ref0::o_EnableTargetWatch|}}) |]
					 	memoryComp(id__,
					 			    const_CacheConsC_stm_ref0_lv,
					 			    const_CacheConsC_stm_ref0_av,
					 			    const_CacheConsC_stm_ref0_pi,
					 			    const_CacheConsC_stm_ref0_k1,
