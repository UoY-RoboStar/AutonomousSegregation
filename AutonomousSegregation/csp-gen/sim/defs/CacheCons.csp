											)\{|get_CLID_DetectCluster|}
										)
										[| {|get_CLID_DecideNewCachePoint,DecideNewCachePoint::entered,terminate|} |]
										dbisim(Clock_CLID_DecideNewCachePoint(id__,0))
									)\{|get_CLID_DecideNewCachePoint|}
								)
								[| {|get_CLID_UpdateCache,UpdateCache::entered,terminate|} |]
								dbisim(Clock_CLID_UpdateCache(id__,0))
							)\{|get_CLID_UpdateCache|}
						)
						) \ union(stateClockSync,enteredSS)
					)
					)
				
				Stateful(id__,cycle_CachePointAssignment_CachePointAssignment) = 
					((let
						getsetLocalChannels = {|get_j,set_j,
						get_counter,set_counter,
						get_L,set_L,
						get_data,set_data,
						get_m,set_m|}
						clockSync = {||}
					within
						(Behaviour(id__,cycle_CachePointAssignment_CachePointAssignment) 
						 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
						 (varMemory(id__,cycle_CachePointAssignment_CachePointAssignment) [| {terminate} |] Clocks(id__))
					 	)\union(getsetLocalChannels,clockSync)
					)
					)
				
				IteratedStateful(id__,cycle_CachePointAssignment_CachePointAssignment) =
					(dbisim(
						sbisim(
							dbisim(
								sbisim(
									dbisim(
										sbisim(
											dbisim(
												sbisim(
													dbisim(
														sbisim(
															IteratedBehaviour(id__,cycle_CachePointAssignment_CachePointAssignment)
															[| {|get_m,set_m,terminate|} |]
															Memory_m(<>)
														)\{|get_m,set_m|}
													)
													[| {|get_data,set_data,terminate|} |]
													Memory_data((0,<>,<>))
												)\{|get_data,set_data|}
											)
											[| {|get_L,set_L,terminate|} |]
											Memory_L((0,0,0,(0,0)))
										)\{|get_L,set_L|}
									)
									[| {|get_counter,set_counter,terminate|} |]
									Memory_counter(1)
								)\{|get_counter,set_counter|}
							)
							[| {|get_j,set_j,terminate|} |]
							Memory_j(0)
						)\{|get_j,set_j|}
					)
					)
				
				-- Visible counterparts
				MachineBody_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) = 
					dbisim((
					let
						finalNodesEntered = {||}
					within
						(dbisim((dbisim((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i0::enter,
							CalculateL::enter,
							DecideNewCachePoint::enter,
							UpdateCache::enter,
							UpdateCurrentCache::enter,
							DetectCluster::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited|})
								transSync = {|internal__.NID_DetectCluster,internal__.NID_CalculateL,internal__.NID_CalculateL,internal__.NID_DecideNewCachePoint,internal__.NID_DecideNewCachePoint,internal__.NID_UpdateCache,internal__.NID_UpdateCurrentCache,endexec__.NID_UpdateCurrentCache,internal__.NID_i0,endexec__.NID_DetectCluster|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i0::VS_O__(id__,cycle_CachePointAssignment_CachePointAssignment)
								   [| { share__, terminate } |] (
								   CalculateL::VS_O__(id__,cycle_CachePointAssignment_CachePointAssignment)
								   [| { share__, terminate } |] (
								   DecideNewCachePoint::VS_O__(id__,cycle_CachePointAssignment_CachePointAssignment)
								   [| { share__, terminate } |] (
								   UpdateCache::VS_O__(id__,cycle_CachePointAssignment_CachePointAssignment)
								   [| { share__, terminate } |] (
								   UpdateCurrentCache::VS_O__(id__,cycle_CachePointAssignment_CachePointAssignment)
								   [| { share__, terminate } |] (
								   DetectCluster::VS_O__(id__,cycle_CachePointAssignment_CachePointAssignment)
								   )
								   )
								   )
								   )
								   )
								 )
								 [[CalculateL::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_CalculateL,internal__.NID_CalculateL|}]]
								 [[DecideNewCachePoint::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_DecideNewCachePoint,internal__.NID_DecideNewCachePoint|}]]
								 [[UpdateCache::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_UpdateCache|}]]
								 [[UpdateCurrentCache::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_UpdateCurrentCache,endexec__.NID_UpdateCurrentCache|}]]
								 [[DetectCluster::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_DetectCluster,endexec__.NID_DetectCluster|}]]
								 [[i0::interrupt <- x__ | x__ <- {|internal__.NID_i0|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								  [[set_L <- setL_L,set_m <- setL_m,set_counter <- setL_counter,set_data <- setL_data]]
								 )
								 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
								 			,setL_L
								 			,setL_m
								 			,setL_counter
								 			,setL_data
								|}) |]
								 ((i0::enter -> Transitions(id__,cycle_CachePointAssignment_CachePointAssignment))
								  [[ share__ <- x__ | x__ <- {| share__,setL_L,setL_m,setL_counter,setL_data |} ]]
								 )
								)[[setL_L <- set_L,setL_m <- set_m,setL_counter <- set_counter,setL_data <- set_data]]
								)
							)
							 \ hideSet)
							[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
							[[ endexec_action <- endexec ]]
							[[ startexec_action <- startexec ]]
						)
						)
						 [| union(stateClockSync,{terminate}) |]
						 StateClocks(id__)
						)\diff(stateClockSync,enteredSS))
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) = 
					dbisim((let
						stateClockSync = {|get_CLID_UpdateCache,UpdateCache::entered,get_CLID_DecideNewCachePoint,DecideNewCachePoint::entered,get_CLID_DetectCluster,DetectCluster::entered,get_CLID_CalculateL,CalculateL::entered,get_CLID_UpdateCurrentCache,UpdateCurrentCache::entered|}
					 within
						(MachineBody_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) [| union(stateClockSync,{terminate}) |] StateClocks(id__)) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				IteratedBehaviour_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) = 
					dbisim((let
						stateClockSync = {|get_CLID_UpdateCache,UpdateCache::entered,get_CLID_DecideNewCachePoint,DecideNewCachePoint::entered,get_CLID_DetectCluster,DetectCluster::entered,get_CLID_CalculateL,CalculateL::entered,get_CLID_UpdateCurrentCache,UpdateCurrentCache::entered|}
					 within
						(dbisim(
							sbisim(
								dbisim(
									sbisim(
										dbisim(
											sbisim(
												dbisim(
													sbisim(
														dbisim(
															sbisim(
																MachineBody_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment)
																[| {|get_CLID_UpdateCurrentCache,UpdateCurrentCache::entered,terminate|} |]
																dbisim(Clock_CLID_UpdateCurrentCache(id__,0))
															)\{|get_CLID_UpdateCurrentCache|}
														)
														[| {|get_CLID_CalculateL,CalculateL::entered,terminate|} |]
														dbisim(Clock_CLID_CalculateL(id__,0))
													)\{|get_CLID_CalculateL|}
												)
												[| {|get_CLID_DetectCluster,DetectCluster::entered,terminate|} |]
												dbisim(Clock_CLID_DetectCluster(id__,0))
											)\{|get_CLID_DetectCluster|}
										)
										[| {|get_CLID_DecideNewCachePoint,DecideNewCachePoint::entered,terminate|} |]
										dbisim(Clock_CLID_DecideNewCachePoint(id__,0))
									)\{|get_CLID_DecideNewCachePoint|}
								)
								[| {|get_CLID_UpdateCache,UpdateCache::entered,terminate|} |]
								dbisim(Clock_CLID_UpdateCache(id__,0))
							)\{|get_CLID_UpdateCache|}
						)
						) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				Stateful_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) = 
					dbisim((let
						getsetLocalChannels = {|get_j,set_j,
						get_counter,set_counter,
						get_L,set_L,
						get_data,set_data,
						get_m,set_m|}
						clockSync = {||}
					within
						(Behaviour_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) 
						 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
						 (varMemory(id__,cycle_CachePointAssignment_CachePointAssignment) [| {terminate} |] Clocks(id__))
					 	)\union(getsetLocalChannels,clockSync)
					)
					)
				
				IteratedStateful_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) =
					(dbisim(
						sbisim(
							dbisim(
								sbisim(
									dbisim(
										sbisim(
											dbisim(
												sbisim(
													dbisim(
														sbisim(
															IteratedBehaviour_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment)
															[| {|get_m,set_m,terminate|} |]
															Memory_m(<>)
														)\{|get_m,set_m|}
													)
													[| {|get_data,set_data,terminate|} |]
													Memory_data((0,<>,<>))
												)\{|get_data,set_data|}
											)
											[| {|get_L,set_L,terminate|} |]
											Memory_L((0,0,0,(0,0)))
										)\{|get_L,set_L|}
									)
									[| {|get_counter,set_counter,terminate|} |]
									Memory_counter(1)
								)\{|get_counter,set_counter|}
							)
							[| {|get_j,set_j,terminate|} |]
							Memory_j(0)
						)\{|get_j,set_j|}
					)
					)
				
				-- END
				
				-- Memory
				-- Memory variables
				Memory_j(j) =
					get_j!j -> Memory_j(j)
					[]
					set_j?x__ -> Memory_j(x__)
					[]
					terminate -> SKIP
				Memory_counter(counter) =
					get_counter!counter -> Memory_counter(counter)
					[]
					set_counter?x__ -> Memory_counter(x__)
					[]
					terminate -> SKIP
				Memory_L(L) =
					get_L!L -> Memory_L(L)
					[]
					set_L?x__ -> Memory_L(x__)
					[]
					terminate -> SKIP
				Memory_data(data) =
					get_data!data -> Memory_data(data)
					[]
					set_data?x__ -> Memory_data(x__)
					[]
					terminate -> SKIP
				Memory_m(m) =
					get_m!m -> Memory_m(m)
					[]
					set_m?x__ -> Memory_m(x__)
					[]
					terminate -> SKIP
				
				-- varMemory process
				varMemory(id__,cycle_CachePointAssignment_CachePointAssignment) = Memory_j(0)
				[| { terminate } |] (
				Memory_counter(1)
				[| { terminate } |] (
				Memory_L((0,0,0,(0,0)))
				[| { terminate } |] (
				Memory_data((0,<>,<>))
				[| { terminate } |] (
				Memory_m(<>)
				)
				)
				)
				)
				
				getsetLocalChannels = {|get_j,set_j,get_counter,set_counter,get_L,set_L,get_data,set_data,get_m,set_m|}
				
				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__,cycle_CachePointAssignment_CachePointAssignment) = STM_VS_O(id__,cycle_CachePointAssignment_CachePointAssignment) \ localClockResets
				D__(id__,cycle_CachePointAssignment_CachePointAssignment) = timed_priority(STM(id__,cycle_CachePointAssignment_CachePointAssignment) \ union(internal_events,localClockResets))
				O__(id__,cycle_CachePointAssignment_CachePointAssignment) = dbisim(D__(id__,cycle_CachePointAssignment_CachePointAssignment))
				VS__(id__,cycle_CachePointAssignment_CachePointAssignment) = FVS__(id__,cycle_CachePointAssignment_CachePointAssignment)
				VS_O__(id__,cycle_CachePointAssignment_CachePointAssignment) = dbisim(FVS__(id__,cycle_CachePointAssignment_CachePointAssignment))
				HEXT__(id__,cycle_CachePointAssignment_CachePointAssignment) = O__(id__,cycle_CachePointAssignment_CachePointAssignment) [|shared_variable_events|] SKIP
				FVS_C__(id__,cycle_CachePointAssignment_CachePointAssignment) = dbisim(timed_priority(STM(id__,cycle_CachePointAssignment_CachePointAssignment) \ internal_events))
				HUP__(id__,cycle_CachePointAssignment_CachePointAssignment) = timed_priority(O__(id__,cycle_CachePointAssignment_CachePointAssignment) [|{share__}|] SKIP)
				
				-- Clocks
				
				Clocks(id__) = terminate -> SKIP
				
				clockSync = {||}
				
				Clock_CLID_UpdateCache(id__,x__) = 
					TimeOut_1(
						UpdateCache::entered -> Clock_CLID_UpdateCache(id__,0)
						[]
						get_CLID_UpdateCache!x__ -> Clock_CLID_UpdateCache(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_UpdateCache(id__,clock_type_plus(x__,1,CLID_UpdateCache_clock_type(id__))))
				Clock_CLID_DecideNewCachePoint(id__,x__) = 
					TimeOut_1(
						DecideNewCachePoint::entered -> Clock_CLID_DecideNewCachePoint(id__,0)
						[]
						get_CLID_DecideNewCachePoint!x__ -> Clock_CLID_DecideNewCachePoint(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_DecideNewCachePoint(id__,clock_type_plus(x__,1,CLID_DecideNewCachePoint_clock_type(id__))))
				Clock_CLID_DetectCluster(id__,x__) = 
					TimeOut_1(
						DetectCluster::entered -> Clock_CLID_DetectCluster(id__,0)
						[]
						get_CLID_DetectCluster!x__ -> Clock_CLID_DetectCluster(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_DetectCluster(id__,clock_type_plus(x__,1,CLID_DetectCluster_clock_type(id__))))
				Clock_CLID_CalculateL(id__,x__) = 
					TimeOut_1(
						CalculateL::entered -> Clock_CLID_CalculateL(id__,0)
						[]
						get_CLID_CalculateL!x__ -> Clock_CLID_CalculateL(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_CalculateL(id__,clock_type_plus(x__,1,CLID_CalculateL_clock_type(id__))))
				Clock_CLID_UpdateCurrentCache(id__,x__) = 
					TimeOut_1(
						UpdateCurrentCache::entered -> Clock_CLID_UpdateCurrentCache(id__,0)
						[]
						get_CLID_UpdateCurrentCache!x__ -> Clock_CLID_UpdateCurrentCache(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_UpdateCurrentCache(id__,clock_type_plus(x__,1,CLID_UpdateCurrentCache_clock_type(id__))))
				
				StateClocks(id__) = dbisim(Clock_CLID_UpdateCache(id__,0))
				[| { terminate } |] (
				dbisim(Clock_CLID_DecideNewCachePoint(id__,0))
				[| { terminate } |] (
				dbisim(Clock_CLID_DetectCluster(id__,0))
				[| { terminate } |] (
				dbisim(Clock_CLID_CalculateL(id__,0))
				[| { terminate } |] (
				dbisim(Clock_CLID_UpdateCurrentCache(id__,0))
				)
				)
				)
				)
				
				stateClockSync = {|get_CLID_UpdateCache,UpdateCache::entered,get_CLID_DecideNewCachePoint,DecideNewCachePoint::entered,get_CLID_DetectCluster,DetectCluster::entered,get_CLID_CalculateL,CalculateL::entered,get_CLID_UpdateCurrentCache,UpdateCurrentCache::entered|}
				
				
				-- Shared memory
				-- Shared memory variables
				
				Memory_VisibleClustersCA(x__) = (
					get_VisibleClustersCA!x__ -> Memory_VisibleClustersCA(x__)
					[]
					registerRead.i_VisibleClustersCA?x__ -> Memory_VisibleClustersCA(x__)
					[]
					terminate -> SKIP
				)
				Memory_CurrentTypeCA(x__) = (
					get_CurrentTypeCA!x__ -> Memory_CurrentTypeCA(x__)
					[]
					registerRead.i_CurrentTypeCA?x__ -> Memory_CurrentTypeCA(x__)
					[]
					terminate -> SKIP
				)
				
				-- sharedVarMemory process
				sharedVarMemory(id__,cycle_CachePointAssignment_CachePointAssignment) = (
				 (terminate -> SKIP
				 )
				 [| { terminate } |]
				 (Memory_VisibleClustersCA(false.(0,<>,<>))
				 [| { terminate } |] (
				 Memory_CurrentTypeCA(false.0)
				 )
				 )
				)
				
				sharedVarSync = union({|get_VisibleClustersCA,
				get_CurrentTypeCA|},
					  {||}
					 )
				
				sharedVarHide = union({|get_VisibleClustersCA,
				get_CurrentTypeCA|},
					  {||}
					 )
				
				}
		endmodule
		module stm_ref2
		exports
			transparent diamond
			transparent sbisim
			transparent dbisim
			transparent chase
		
			-- Transition identifiers
			-- declaring identifiers of transitions
			datatype NIDS = 
			              NID_OAEnabled|
			              NID_OADisabled|
			              NID_i1|
			              NID_j0|
			              NID_j1|
			              NID_j2|
			              NID_j3
			
			channel internal__ : NIDS
			
			-- Flow channels		
			channel interrupt
			channel exited
			channel exit
			channel terminate
			
			-- Variable channels
			channel get_closest_angle, set_closest_angle, setL_closest_angle, setR_closest_angle: core_real
			channel get_closest_distance, set_closest_distance, setL_closest_distance, setR_closest_distance: core_real
			channel get_av, set_av, setL_av, setR_av: core_real
			channel get_lv, set_lv, setL_lv, setR_lv: core_real
			channel get_NOA_Move, set_NOA_Move, setL_NOA_Move, setR_NOA_Move: vector_real_2
			channel get_current_speed, set_current_speed, setL_current_speed, setR_current_speed: core_real
			channel get_oaCmd, set_oaCmd, setL_oaCmd, setR_oaCmd: Vec2
			
			-- Shared variable channels
			
			-- Local variable channels for defined operations that are required by the state machine
			
			-- Declaring state machine events
			
			-- Declaring call and ret events for undefined operations
			
			enterSS = {|
			OAEnabled::enter,
			OADisabled::enter,
			i1::enter,
			j0::enter,
			j1::enter,
			j2::enter,
			j3::enter
			|}
			
			enteredSS = 	{|
			OAEnabled::entered,
			OADisabled::entered
			|}
			
			internal_events = union(enteredSS,union(enterSS,{|interrupt,exited|}))
			
			shared_variable_events = {|
			|}
			
			datatype ClockSet = 
				CLID_T
			
			channel clockReset, clockResetL, clockResetR : ClockSet
			
			localClockResets = {|clockReset.CLID_T|}
			
			
			channel get_CLID_OAEnabled : core_clock_type 
			channel get_CLID_T : core_clock_type 
			channel get_CLID_OADisabled : core_clock_type 
			--channel increment__
			
			CLID_OAEnabled_clock_type(id__,
					          const_ObstacleAvoidance_pi,
					          const_ObstacleAvoidance_DISTANCE,
					          const_ObstacleAvoidance_min_range,
					          const_ObstacleAvoidance_max_range,
